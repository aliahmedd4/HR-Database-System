@model IEnumerable<Milstone3_WebApp.Department>
@{
    ViewData["Title"] = "Department view";
    var counts = ViewBag.DeptCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="page-header">
    <div>
        <h1 class="page-title">Department view</h1>
        <p class="page-subtitle">Select a department to see its members</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-diagram-3 me-1"></i>Full hierarchy
    </a>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-building" style="font-size:40px;color:var(--text-muted);display:block;margin-bottom:12px;"></i>
            <div class="fw-600 fs-13" style="color:var(--text-secondary);">No departments found</div>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var d in Model)
        {
            var count = counts.ContainsKey(d.DepartmentId) ? counts[d.DepartmentId] : 0;
            <div class="col-md-4 col-sm-6">
                <a asp-action="DepartmentView" asp-route-id="@d.DepartmentId"
                   class="card h-100 text-decoration-none" style="transition:background .12s;">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3 mb-2">
                            <span style="width:40px;height:40px;border-radius:10px;background:var(--accent-light);color:var(--accent);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;">
                                <i class="bi bi-building"></i>
                            </span>
                            <div>
                                <div class="fw-600 fs-13" style="color:var(--text-primary);">@d.DepartmentName</div>
                                <div class="fs-12 text-muted-custom">@count member@(count == 1 ? "" : "s")</div>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(d.Purpose))
                        {
                            <div class="fs-12 text-secondary-custom">@d.Purpose</div>
                        }
                    </div>
                </a>
            </div>
        }
    </div>
}
