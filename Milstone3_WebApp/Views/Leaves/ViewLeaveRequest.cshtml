@model Milstone3_WebApp.LeaveRequest

@{
    ViewData["Title"] = "Leave Request Details";
}

<div class="welcome-banner mb-4">
    <h2>Leave Request Details</h2>
    <p>View complete information about your leave request.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm p-4">
    <h4 class="mb-3">Leave Request #@Model.RequestId</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-3">Employee</dt>
        <dd class="col-sm-9">
            <strong>@(Model.Employee?.FullName ?? $"Employee #{Model.EmployeeId}")</strong>
            @if (Model.Employee != null)
            {
                <br /><small class="text-muted">@Model.Employee.EmployeeCode</small>
            }
        </dd>

        <dt class="col-sm-3">Leave Type</dt>
        <dd class="col-sm-9">
            <span class="badge bg-primary">@(Model.Leave?.LeaveType ?? Model.Leave?.LeaveDescription ?? "N/A")</span>
        </dd>

        <dt class="col-sm-3">Start Date</dt>
        <dd class="col-sm-9">@Model.StartDate.ToString("MMMM dd, yyyy")</dd>

        <dt class="col-sm-3">End Date</dt>
        <dd class="col-sm-9">@Model.EndDate.ToString("MMMM dd, yyyy")</dd>

        <dt class="col-sm-3">Total Days</dt>
        <dd class="col-sm-9"><strong>@Model.TotalDays</strong> days</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">
            @{
                var statusClass = Model.Status?.ToLower() switch
                {
                    "approved" => "bg-success",
                    "pending" => "bg-warning",
                    "rejected" => "bg-danger",
                    "cancelled" => "bg-secondary",
                    _ => "bg-secondary"
                };
            }
            <span class="badge @statusClass">@(Model.Status ?? "Pending")</span>
            @if (Model.IsIrregular == true)
            {
                <span class="badge bg-danger ms-2">
                    <i class="bi bi-exclamation-triangle"></i> Irregular
                </span>
            }
        </dd>

        <dt class="col-sm-3">Submitted Date</dt>
        <dd class="col-sm-9">@(Model.SubmittedAt?.ToString("MMMM dd, yyyy 'at' hh:mm tt") ?? "N/A")</dd>

        @if (!string.IsNullOrEmpty(Model.Reason))
        {
            <dt class="col-sm-3">Reason</dt>
            <dd class="col-sm-9">@Model.Reason</dd>
        }

        @if (!string.IsNullOrEmpty(Model.Justification))
        {
            <dt class="col-sm-3">Justification</dt>
            <dd class="col-sm-9">@Model.Justification</dd>
        }

        @if (Model.ApprovedByNavigation != null)
        {
            <dt class="col-sm-3">Approved/Rejected By</dt>
            <dd class="col-sm-9">@Model.ApprovedByNavigation.FullName</dd>
        }

        @if (Model.ApprovedAt.HasValue)
        {
            <dt class="col-sm-3">Approved/Rejected Date</dt>
            <dd class="col-sm-9">@Model.ApprovedAt.Value.ToString("MMMM dd, yyyy 'at' hh:mm tt")</dd>
        }

        @if (!string.IsNullOrEmpty(Model.RejectionReason))
        {
            <dt class="col-sm-3">Rejection Reason</dt>
            <dd class="col-sm-9">
                <span class="text-danger">@Model.RejectionReason</span>
            </dd>
        }

        @if (!string.IsNullOrEmpty(Model.OverrideReason))
        {
            <dt class="col-sm-3">Override Reason</dt>
            <dd class="col-sm-9">
                <span class="text-warning">@Model.OverrideReason</span>
            </dd>
        }

        @if (Model.LeaveDocuments != null && Model.LeaveDocuments.Any())
        {
            <dt class="col-sm-3">Attachments</dt>
            <dd class="col-sm-9">
                <ul class="list-unstyled">
                    @foreach (var doc in Model.LeaveDocuments)
                    {
                        <li>
                            <a href="@doc.FilePath" target="_blank" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-file-earmark"></i> @(doc.DocumentType ?? "Document")
                            </a>
                        </li>
                    }
                </ul>
            </dd>
        }
    </dl>

    <div class="form-actions mt-4 d-flex justify-content-between">
        <a asp-action="MyLeaveHistory" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to My Leave History
        </a>
        @if (Model.Status == "Pending" && (User.IsInRole("Employee") || User.IsInRole("HRAdmin") || User.IsInRole("SystemAdmin")))
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Request New Leave
            </a>
        }
    </div>
</div>

