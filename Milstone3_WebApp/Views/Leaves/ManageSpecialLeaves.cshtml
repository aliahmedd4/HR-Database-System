@model IEnumerable<Milstone3_WebApp.Leave>

@{
    ViewData["Title"] = "Manage Special Leaves";
}

<div class="welcome-banner mb-4">
    <h2>Manage Special Leaves</h2>
    <p>Configure and manage special leave types such as maternity, paternity, bereavement, etc.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm p-4 mb-3">
    <h5>Create Special Leave Type</h5>
    <form asp-action="CreateSpecialLeave" method="post" class="row g-3">
        <div class="col-md-3">
            <label for="leaveType" class="form-label">Leave Type <span class="text-danger">*</span></label>
            <input type="text" name="leaveType" id="leaveType" class="form-control" 
                   placeholder="e.g., Maternity, Paternity, Bereavement" required />
        </div>
        <div class="col-md-3">
            <label for="description" class="form-label">Description <span class="text-danger">*</span></label>
            <input type="text" name="description" id="description" class="form-control" required />
        </div>
        <div class="col-md-2">
            <label for="maxDays" class="form-label">Max Days/Year <span class="text-danger">*</span></label>
            <input type="number" name="maxDays" id="maxDays" class="form-control" min="0" required />
        </div>
        <div class="col-md-2">
            <div class="form-check mt-4">
                <input type="checkbox" name="isPaid" id="isPaid" class="form-check-input" value="true" checked />
                <input type="hidden" name="isPaid" value="false" />
                <label for="isPaid" class="form-check-label">Paid</label>
            </div>
        </div>
        <div class="col-md-2">
            <div class="form-check mt-4">
                <input type="checkbox" name="requiresApproval" id="requiresApproval" class="form-check-input" value="true" checked />
                <input type="hidden" name="requiresApproval" value="false" />
                <label for="requiresApproval" class="form-check-label">Requires Approval</label>
            </div>
        </div>
        <div class="col-md-12">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create Special Leave
            </button>
        </div>
    </form>
</div>

<div class="card shadow-sm p-4">
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No special leave types found.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Leave Type</th>
                        <th>Description</th>
                        <th>Max Days/Year</th>
                        <th>Paid</th>
                        <th>Requires Approval</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var leave in Model)
                    {
                        <tr>
                            <td>
                                <strong>@leave.LeaveType</strong>
                            </td>
                            <td>@leave.LeaveDescription</td>
                            <td>@leave.MaxDaysPerYear</td>
                            <td>
                                @if (leave.IsPaid == true)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td>
                                @if (leave.RequiresApproval == true)
                                {
                                    <span class="badge bg-warning">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td>
                                @if (leave.IsActive == true)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <a asp-action="EditLeaveType" asp-route-id="@leave.LeaveId" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <a asp-action="Details" asp-route-id="@leave.LeaveId" class="btn btn-sm btn-info">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Leave Types
    </a>
</div>

