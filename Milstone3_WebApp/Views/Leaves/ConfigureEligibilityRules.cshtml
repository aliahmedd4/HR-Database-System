@model IEnumerable<Milstone3_WebApp.LeavePolicy>

@{
    ViewData["Title"] = "Configure Eligibility Rules";
}

<div class="welcome-banner mb-4">
    <h2>Configure Eligibility Rules</h2>
    <p>Set eligibility criteria and rules for leave types.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm p-4">
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No leave policies found. Create policies first to configure eligibility rules.
            <br />
            <a asp-action="ConfigureLeavePolicies" class="btn btn-primary mt-2">
                <i class="bi bi-plus-circle"></i> Go to Configure Policies
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Policy Name</th>
                        <th>Leave Type</th>
                        <th>Eligibility Months</th>
                        <th>Eligibility Rules</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var policy in ViewBag.AllPolicies as IEnumerable<Milstone3_WebApp.LeavePolicy>)
                    {
                        <tr>
                            <td><strong>@policy.Name</strong></td>
                            <td>
                                <span class="badge bg-info">@(policy.Leave?.LeaveType ?? "N/A")</span>
                            </td>
                            <td>@(policy.EligibilityMonths ?? 0) months</td>
                            <td>
                                @if (!string.IsNullOrEmpty(policy.EligibilityRules))
                                {
                                    <small>@policy.EligibilityRules</small>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-warning" 
                                        onclick="showEligibilityModal(@policy.PolicyId, '@(policy.EligibilityRules ?? "")', @(policy.EligibilityMonths ?? 0))">
                                    <i class="bi bi-pencil"></i> Configure
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Eligibility Rules Modal -->
<div class="modal fade" id="eligibilityModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Configure Eligibility Rules</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateEligibilityRules" method="post">
                <div class="modal-body">
                    <input type="hidden" name="policyId" id="eligPolicyId" />
                    <div class="mb-3">
                        <label for="eligibilityMonths" class="form-label">Eligibility Months (Minimum tenure required)</label>
                        <input type="number" name="eligibilityMonths" id="eligibilityMonths" class="form-control" min="0" required />
                        <small class="form-text text-muted">Minimum months of service required to be eligible for this leave type</small>
                    </div>
                    <div class="mb-3">
                        <label for="eligibilityRules" class="form-label">Eligibility Rules Description</label>
                        <textarea name="eligibilityRules" id="eligibilityRules" class="form-control" rows="4" 
                                  placeholder="e.g., Full-time employees only, Minimum 6 months tenure, Available after probation period"></textarea>
                        <small class="form-text text-muted">Describe the eligibility criteria in detail</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Rules</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function showEligibilityModal(policyId, eligibilityRules, eligibilityMonths) {
        document.getElementById('eligPolicyId').value = policyId;
        document.getElementById('eligibilityRules').value = eligibilityRules || '';
        document.getElementById('eligibilityMonths').value = eligibilityMonths || 0;
        var modal = new bootstrap.Modal(document.getElementById('eligibilityModal'));
        modal.show();
    }
</script>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Leave Types
    </a>
    <a asp-action="ConfigureLeavePolicies" class="btn btn-primary">
        <i class="bi bi-gear"></i> Configure Policies
    </a>
</div>

