@model Milstone3_WebApp.Leave

@{
    ViewData["Title"] = "Delete Leave Type";
}

<div class="welcome-banner">
    <h2>Delete Leave Type</h2>
    <p>Are you sure you want to delete this leave type? This action cannot be undone.</p>
</div>

<div class="card">
    <h4>Leave Details</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Leave Type</dt>
        <dd class="col-sm-9">@Model.LeaveType</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@Model.LeaveDescription</dd>

        <dt class="col-sm-3">Additional Notes</dt>
        <dd class="col-sm-9">@Model.Description</dd>

        <dt class="col-sm-3">Paid Leave</dt>
        <dd class="col-sm-9">@Model.IsPaid</dd>

        <dt class="col-sm-3">Max Days Per Year</dt>
        <dd class="col-sm-9">@Model.MaxDaysPerYear</dd>

        <dt class="col-sm-3">Requires Approval</dt>
        <dd class="col-sm-9">@Model.RequiresApproval</dd>

        <dt class="col-sm-3">Active</dt>
        <dd class="col-sm-9">@Model.IsActive</dd>
    </dl>

    <form asp-action="Delete" class="form-actions">
        <input type="hidden" asp-for="LeaveId" />
        <button type="submit" class="btn btn-danger">Delete Leave Type</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
