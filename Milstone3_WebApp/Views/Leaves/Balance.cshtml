@model IEnumerable<Milstone3_WebApp.Models.LeaveBalanceDto>

@{
    ViewData["Title"] = "Leave Balance";
}

<div class="welcome-banner mb-4">
    <h2>Leave Balance</h2>
    <p>Overview of leave entitlements for this employee.</p>
</div>

<div class="row">
    @if (Model != null && Model.Any())
    {
        @foreach (var e in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">@(e.LeaveType ?? "Unknown Leave Type")</h5>
                        @if (e.Balance_Days > 0)
                        {
                            <span class="badge bg-success">Remaining: @e.Balance_Days</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">No Days Left</span>
                        }
                    </div>
                    <div class="card-body">
                        <p><strong>Allocated Days:</strong> @e.Allocated_Days</p>
                        <p><strong>Used Days:</strong> @e.UsedDays</p>
                        <p><strong>Remaining Days:</strong> @e.Balance_Days</p>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> No leave balance information available. 
                Please contact HR to set up your leave entitlements.
            </div>
        </div>
    }
</div>

<div class="mt-3">
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Request New Leave
    </a>
    <a asp-action="MyLeaveHistory" class="btn btn-info">
        <i class="bi bi-clock-history"></i> View My Leave History
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Leave Types
    </a>
</div>
