@model IEnumerable<Milstone3_WebApp.Models.LeaveBalanceDto>
@{
    ViewData["Title"] = "Leave balance";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Leave balance</h1>
        <p class="page-subtitle">Your leave entitlements for @DateTime.Now.Year</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="MyLeaveHistory" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-clock-history me-1"></i>History
        </a>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus me-1"></i>Request leave
        </a>
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-wallet2" style="font-size:40px;color:var(--text-muted);display:block;margin-bottom:12px;"></i>
            <div class="fw-600 fs-13" style="color:var(--text-secondary);">No leave entitlements set up yet</div>
            <div class="fs-12 text-muted-custom">Contact HR to configure your leave allowances.</div>
        </div>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        @foreach (var e in Model)
        {
            var pct  = e.Allocated_Days > 0 ? (int)Math.Round((double)e.UsedDays / (double)e.Allocated_Days * 100) : 0;
            var low  = e.Balance_Days <= 2;
            var none = e.Balance_Days <= 0;
            <div class="col-md-4 col-sm-6">
                <div class="card h-100 @(none ? "danger" : low ? "warning" : "success") stat-card" style="padding:20px;">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="fw-600 fs-13">@(e.LeaveType ?? "Leave")</div>
                        @if (none)
                        {
                            <span class="pill pill-rejected">No days left</span>
                        }
                        else if (low)
                        {
                            <span class="pill pill-expiring">Low balance</span>
                        }
                        else
                        {
                            <span class="pill pill-approved">@e.Balance_Days days left</span>
                        }
                    </div>

                    <!-- Progress bar -->
                    <div style="background:var(--border);border-radius:4px;height:6px;margin-bottom:16px;">
                        <div style="background:@(none ? "var(--danger)" : low ? "var(--warning)" : "var(--success)");
                                    width:@(Math.Min(pct,100))%;height:6px;border-radius:4px;transition:width .3s;"></div>
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;text-align:center;">
                        <div>
                            <div class="fs-12 text-muted-custom">Allocated</div>
                            <div class="fw-600 fs-13">@e.Allocated_Days</div>
                        </div>
                        <div>
                            <div class="fs-12 text-muted-custom">Used</div>
                            <div class="fw-600 fs-13">@e.UsedDays</div>
                        </div>
                        <div>
                            <div class="fs-12 text-muted-custom">Remaining</div>
                            <div class="fw-600 fs-13" style="color:@(none ? "var(--danger)" : low ? "var(--warning)" : "var(--success)");">@e.Balance_Days</div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
