@model IEnumerable<Milstone3_WebApp.LeavePolicy>

@{
    ViewData["Title"] = "Configure Leave Policies";
}

<div class="welcome-banner mb-4">
    <h2>Configure Leave Policies</h2>
    <p>Configure policies, accrual rates, and rules for leave types.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm p-4 mb-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Leave Policies</h5>
        <a asp-action="CreateLeavePolicy" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create New Policy
        </a>
    </div>
    
    <form method="get" class="row g-3">
        <div class="col-md-10">
            <label for="leaveId" class="form-label">Filter by Leave Type</label>
            <select name="leaveId" id="leaveId" class="form-select">
                <option value="">All Leave Types</option>
                @foreach (var leave in ViewBag.Leaves as IEnumerable<Milstone3_WebApp.Leave>)
                {
                    <option value="@leave.LeaveId" selected="@(ViewBag.LeaveIdFilter == leave.LeaveId)">@leave.LeaveType</option>
                }
            </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary me-2">Filter</button>
            <a asp-action="ConfigureLeavePolicies" class="btn btn-secondary">Clear</a>
        </div>
    </form>
</div>

<div class="card shadow-sm p-4">
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No leave policies found.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Policy Name</th>
                        <th>Leave Type</th>
                        <th>Purpose</th>
                        <th>Eligibility Months</th>
                        <th>Accrual Rate</th>
                        <th>Max Balance</th>
                        <th>Reset on New Year</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var policy in Model)
                    {
                        <tr>
                            <td><strong>@policy.Name</strong></td>
                            <td>
                                <span class="badge bg-info">@(policy.Leave?.LeaveType ?? "N/A")</span>
                            </td>
                            <td>@(policy.Purpose ?? "-")</td>
                            <td>@(policy.EligibilityMonths ?? 0) months</td>
                            <td>@(policy.AccrualRate ?? 0)%</td>
                            <td>@(policy.MaxBalance ?? 0) days</td>
                            <td>
                                @if (policy.ResetOnNewYear == true)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td>
                                @if (policy.IsActive == true)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>
                            <td>
                                <a asp-action="EditLeavePolicy" asp-route-id="@policy.PolicyId" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Leave Types
    </a>
</div>

