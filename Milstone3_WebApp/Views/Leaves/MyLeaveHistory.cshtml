@model IEnumerable<Milstone3_WebApp.LeaveRequest>

@{
    ViewData["Title"] = "My Leave History";
}

<div class="welcome-banner">
    <h2>My Leave History</h2>
    <p>View all your leave requests and their status.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm p-4">
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No leave requests found. 
            <a asp-action="Create" class="alert-link">Submit your first leave request</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Leave Type</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Total Days</th>
                        <th>Status</th>
                        <th>Submitted Date</th>
                        <th>Reason</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var leave in Model)
                    {
                        <tr>
                            <td>
                                @if (leave.Leave != null)
                                {
                                    <span class="badge bg-primary">@(leave.Leave.LeaveDescription ?? leave.Leave.LeaveType ?? "N/A")</span>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                            <td>@leave.StartDate.ToString("MMM dd, yyyy")</td>
                            <td>@leave.EndDate.ToString("MMM dd, yyyy")</td>
                            <td><strong>@leave.TotalDays</strong> days</td>
                            <td>
                                @{
                                    var statusClass = leave.Status?.ToLower() switch
                                    {
                                        "approved" => "bg-success",
                                        "pending" => "bg-warning",
                                        "rejected" => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @statusClass">@(leave.Status ?? "Unknown")</span>
                            </td>
                            <td>@(leave.SubmittedAt?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(leave.Reason))
                                {
                                    <span title="@leave.Reason">
                                        @(leave.Reason.Length > 50 ? leave.Reason.Substring(0, 50) + "..." : leave.Reason)
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <a asp-action="ViewLeaveRequest" asp-route-id="@leave.RequestId" class="btn btn-sm btn-info">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <p class="text-muted">
                <small>Total Leave Requests: <strong>@Model.Count()</strong></small>
            </p>
        </div>
    }
</div>

<div class="mt-3">
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Request New Leave
    </a>
    <a asp-action="Balance" class="btn btn-info">
        <i class="bi bi-calendar-check"></i> View Leave Balance
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Leave Types
    </a>
</div>

