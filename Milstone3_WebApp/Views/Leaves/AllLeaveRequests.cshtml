@model IEnumerable<Milstone3_WebApp.LeaveRequest>

@{
    ViewData["Title"] = "All Leave Requests";
}

<div class="welcome-banner mb-4">
    <h2>All Leave Requests</h2>
    <p>View and manage all leave requests in the system.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm p-4 mb-3">
    <h5>Filters</h5>
    <form method="get" class="row g-3">
        <div class="col-md-4">
            <label for="status" class="form-label">Status</label>
            <select name="status" id="status" class="form-select">
                <option value="">All Statuses</option>
                <option value="Pending" selected="@(ViewBag.StatusFilter == "Pending")">Pending</option>
                <option value="Approved" selected="@(ViewBag.StatusFilter == "Approved")">Approved</option>
                <option value="Rejected" selected="@(ViewBag.StatusFilter == "Rejected")">Rejected</option>
                <option value="Cancelled" selected="@(ViewBag.StatusFilter == "Cancelled")">Cancelled</option>
            </select>
        </div>
        <div class="col-md-4">
            <label for="employeeId" class="form-label">Employee ID</label>
            <input type="number" name="employeeId" id="employeeId" class="form-control" value="@ViewBag.EmployeeIdFilter" placeholder="Filter by Employee ID">
        </div>
        <div class="col-md-4 d-flex align-items-end">
            <button type="submit" class="btn btn-primary me-2">
                <i class="bi bi-funnel"></i> Filter
            </button>
            <a asp-action="AllLeaveRequests" class="btn btn-secondary">
                <i class="bi bi-x-circle"></i> Clear
            </a>
        </div>
    </form>
</div>

<div class="card shadow-sm p-4">
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No leave requests found.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Request ID</th>
                        <th>Employee</th>
                        <th>Leave Type</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Total Days</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th>Approved By</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var leave in Model)
                    {
                        <tr>
                            <td>#@leave.RequestId</td>
                            <td>
                                <strong>@(leave.Employee?.FullName ?? $"Employee #{leave.EmployeeId}")</strong><br />
                                <small class="text-muted">ID: @leave.EmployeeId</small>
                            </td>
                            <td>
                                <span class="badge bg-info">@(leave.Leave?.LeaveType ?? "N/A")</span>
                            </td>
                            <td>@leave.StartDate.ToString("MMM dd, yyyy")</td>
                            <td>@leave.EndDate.ToString("MMM dd, yyyy")</td>
                            <td><strong>@leave.TotalDays</strong> days</td>
                            <td>
                                @{
                                    var statusClass = leave.Status?.ToLower() switch
                                    {
                                        "approved" => "bg-success",
                                        "pending" => "bg-warning",
                                        "rejected" => "bg-danger",
                                        "cancelled" => "bg-secondary",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @statusClass">@(leave.Status ?? "Pending")</span>
                                @if (leave.IsIrregular == true)
                                {
                                    <span class="badge bg-danger ms-1">
                                        <i class="bi bi-exclamation-triangle"></i> Irregular
                                    </span>
                                }
                            </td>
                            <td>@(leave.SubmittedAt?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                            <td>
                                @if (leave.ApprovedByNavigation != null)
                                {
                                    @leave.ApprovedByNavigation.FullName
                                    <br />
                                    <small class="text-muted">@(leave.ApprovedAt?.ToString("MMM dd, yyyy") ?? "")</small>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex flex-column gap-1">
                                    <a asp-action="ViewLeaveRequest" asp-route-id="@leave.RequestId" class="btn btn-sm btn-info">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                    @if (leave.Status == "Pending" || leave.Status == null)
                                    {
                                        <form asp-action="Approve" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@leave.RequestId" />
                                            <button type="submit" class="btn btn-sm btn-success w-100">
                                                <i class="bi bi-check-circle"></i> Approve
                                            </button>
                                        </form>
                                        <button type="button" class="btn btn-sm btn-danger w-100" 
                                                onclick="showRejectModal(@leave.RequestId)">
                                            <i class="bi bi-x-circle"></i> Reject
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-warning w-100" 
                                                onclick="showOverrideModal(@leave.RequestId, '@leave.Status')">
                                            <i class="bi bi-arrow-repeat"></i> Override
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <p class="text-muted">
                <small>Total Requests: <strong>@Model.Count()</strong></small>
            </p>
        </div>
    }
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Reject Leave Request</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Reject" method="post">
                <div class="modal-body">
                    <input type="hidden" name="id" id="rejectRequestIdHR" />
                    <div class="mb-3">
                        <label for="rejectionReasonHR" class="form-label">Rejection Reason <span class="text-danger">*</span></label>
                        <textarea name="rejectionReason" id="rejectionReasonHR" class="form-control" rows="3" 
                                  placeholder="Please provide a reason for rejection..." required></textarea>
                        <small class="form-text text-muted">This reason will be visible to the employee.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Confirm Rejection</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Override Modal -->
<div class="modal fade" id="overrideModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Override Leave Decision</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Override" method="post">
                <div class="modal-body">
                    <input type="hidden" name="requestId" id="overrideRequestId" />
                    <div class="mb-3">
                        <label for="status" class="form-label">New Status</label>
                        <select name="status" id="status" class="form-select" required>
                            <option value="Approved">Approved</option>
                            <option value="Rejected">Rejected</option>
                            <option value="Pending">Pending</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="overrideReason" class="form-label">Override Reason</label>
                        <textarea name="overrideReason" id="overrideReason" class="form-control" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">Override Decision</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function showRejectModal(requestId) {
        document.getElementById('rejectRequestIdHR').value = requestId;
        document.getElementById('rejectionReasonHR').value = '';
        var modal = new bootstrap.Modal(document.getElementById('rejectModal'));
        modal.show();
    }
    
    function showOverrideModal(requestId, currentStatus) {
        document.getElementById('overrideRequestId').value = requestId;
        var modal = new bootstrap.Modal(document.getElementById('overrideModal'));
        modal.show();
    }
</script>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Leave Types
    </a>
</div>

