@model IEnumerable<Milstone3_WebApp.LeaveRequest>
@{
    ViewData["Title"] = "Leave requests";
}

<div class="page-header">
    <div>
        <h1 class="page-title">All leave requests</h1>
        <p class="page-subtitle">Review, approve, or override all employee leave requests</p>
    </div>
</div>

<!-- Filters -->
<div class="card mb-3">
    <div class="card-body" style="padding:14px 18px!important;">
        <form method="get" class="d-flex flex-wrap gap-3 align-items-end">
            <div>
                <label class="form-label mb-1">Status</label>
                <select name="status" class="form-select" style="width:160px;">
                    <option value="">All statuses</option>
                    <option value="Pending"   selected="@(ViewBag.StatusFilter == "Pending"   ? "selected" : null)">Pending</option>
                    <option value="Approved"  selected="@(ViewBag.StatusFilter == "Approved"  ? "selected" : null)">Approved</option>
                    <option value="Rejected"  selected="@(ViewBag.StatusFilter == "Rejected"  ? "selected" : null)">Rejected</option>
                    <option value="Cancelled" selected="@(ViewBag.StatusFilter == "Cancelled" ? "selected" : null)">Cancelled</option>
                </select>
            </div>
            <div>
                <label class="form-label mb-1">Employee ID</label>
                <input type="number" name="employeeId" class="form-control" style="width:140px;"
                       value="@ViewBag.EmployeeIdFilter" placeholder="Any" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
                <a asp-action="AllLeaveRequests" class="btn btn-outline-secondary btn-sm">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="dt-controls px-4 pt-4 pb-2">
            <div class="dt-search">
                <i class="bi bi-search search-icon"></i>
                <input type="text" placeholder="Search requests…"
                       data-dt-search="leaveTable" data-dt-pagesize="15" />
            </div>
            <span class="fs-12 text-muted-custom">@Model.Count() requests</span>
        </div>

        <div class="admin-table-wrap">
            <table class="admin-table" id="leaveTable">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th data-sort>Employee</th>
                        <th>Leave type</th>
                        <th data-sort>Start</th>
                        <th data-sort>End</th>
                        <th>Days</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th>Approved by</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var leave in Model)
                    {
                        <tr>
                            <td class="text-muted-custom">#@leave.RequestId</td>
                            <td>
                                <div class="fw-600">@(leave.Employee?.FullName ?? $"Employee #{leave.EmployeeId}")</div>
                                <div class="fs-12 text-muted-custom">ID: @leave.EmployeeId</div>
                            </td>
                            <td><span class="pill pill-onleave">@(leave.Leave?.LeaveType ?? "—")</span></td>
                            <td>@leave.StartDate.ToString("dd MMM yyyy")</td>
                            <td>@leave.EndDate.ToString("dd MMM yyyy")</td>
                            <td class="fw-600">@leave.TotalDays d</td>
                            <td>
                                @{
                                    var pc = (leave.Status?.ToLower()) switch {
                                        "approved"  => "pill-approved",
                                        "rejected"  => "pill-rejected",
                                        "cancelled" => "pill-inactive",
                                        _           => "pill-pending"
                                    };
                                }
                                <span class="pill @pc">@(leave.Status ?? "Pending")</span>
                                @if (leave.IsIrregular == true)
                                {
                                    <span class="pill pill-rejected ms-1" title="Irregular">Irregular</span>
                                }
                            </td>
                            <td class="text-muted-custom">@(leave.SubmittedAt?.ToString("dd MMM") ?? "—")</td>
                            <td class="text-muted-custom">
                                @if (leave.ApprovedByNavigation != null)
                                {
                                    <div>@leave.ApprovedByNavigation.FullName</div>
                                    <div class="fs-12">@(leave.ApprovedAt?.ToString("dd MMM") ?? "")</div>
                                }
                                else { <text>—</text> }
                            </td>
                            <td>
                                <div class="d-flex flex-column gap-1" style="min-width:90px;">
                                    <a asp-action="ViewLeaveRequest" asp-route-id="@leave.RequestId"
                                       class="btn btn-sm btn-outline-secondary">View</a>
                                    @if (leave.Status == "Pending" || leave.Status == null)
                                    {
                                        <form asp-action="Approve" method="post">
                                            <input type="hidden" name="id" value="@leave.RequestId" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary w-100">Approve</button>
                                        </form>
                                        <button class="btn btn-sm btn-outline-danger"
                                                onclick="showRejectModal(@leave.RequestId)">Reject</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary"
                                                onclick="showOverrideModal(@leave.RequestId, '@leave.Status')">Override</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="10" class="text-center py-4 text-muted-custom">No leave requests found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="dt-pagination px-4 pb-3">
            <span class="fs-12 text-muted-custom" data-dt-info="leaveTable"></span>
            <div class="dt-page-btns" data-dt-pages="leaveTable"></div>
        </div>
    </div>
</div>

<!-- Reject modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:12px;border-color:var(--border);">
            <div class="modal-header" style="border-color:var(--border);">
                <h5 class="modal-title fs-13 fw-600">Reject leave request</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Reject" method="post">
                <div class="modal-body">
                    <input type="hidden" name="id" id="rejectRequestId" />
                    <div class="mb-3">
                        <label class="form-label">Rejection reason <span class="text-danger">*</span></label>
                        <textarea name="rejectionReason" id="rejectionReason" class="form-control" rows="3"
                                  placeholder="State the reason — this will be visible to the employee." required></textarea>
                    </div>
                </div>
                <div class="modal-footer" style="border-color:var(--border);">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger btn-sm">Confirm rejection</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Override modal -->
<div class="modal fade" id="overrideModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:12px;border-color:var(--border);">
            <div class="modal-header" style="border-color:var(--border);">
                <h5 class="modal-title fs-13 fw-600">Override leave decision</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Override" method="post">
                <div class="modal-body">
                    <input type="hidden" name="requestId" id="overrideRequestId" />
                    <div class="mb-3">
                        <label class="form-label">New status</label>
                        <select name="status" class="form-select" required>
                            <option value="Approved">Approved</option>
                            <option value="Rejected">Rejected</option>
                            <option value="Pending">Pending</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Override reason</label>
                        <textarea name="overrideReason" class="form-control" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer" style="border-color:var(--border);">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning btn-sm">Override decision</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function showRejectModal(id) {
    document.getElementById('rejectRequestId').value = id;
    document.getElementById('rejectionReason').value = '';
    new bootstrap.Modal(document.getElementById('rejectModal')).show();
}
function showOverrideModal(id) {
    document.getElementById('overrideRequestId').value = id;
    new bootstrap.Modal(document.getElementById('overrideModal')).show();
}
</script>
}
