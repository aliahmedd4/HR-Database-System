@model IEnumerable<Milstone3_WebApp.Models.PendingLeaveDto>

@{
    ViewData["Title"] = "Team Leave Requests";
}

<div class="welcome-banner">
    <h2>Team Leave Requests</h2>
    <p>View and manage all leave requests from your team members.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Status Filter -->
<div class="card shadow-sm p-3 mb-3">
    <form method="get" class="row g-3">
        <div class="col-md-10">
            <label for="statusFilter" class="form-label">Filter by Status</label>
            <select name="statusFilter" id="statusFilter" class="form-select" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                <option value="Pending" selected="@(ViewBag.StatusFilter == "Pending")">Pending</option>
                <option value="Approved" selected="@(ViewBag.StatusFilter == "Approved")">Approved</option>
                <option value="Rejected" selected="@(ViewBag.StatusFilter == "Rejected")">Rejected</option>
                <option value="Cancelled" selected="@(ViewBag.StatusFilter == "Cancelled")">Cancelled</option>
            </select>
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <a asp-action="Pending" class="btn btn-secondary w-100">Clear Filter</a>
        </div>
    </form>
</div>

<div class="card shadow-sm p-4">
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No leave requests found in the system.
            <br /><small class="text-muted">All leave requests from all employees will appear here once they are submitted.</small>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Employee</th>
                        <th>Leave Type</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Total Days</th>
                        <th>Reason</th>
                        <th>Status</th>
                        <th>Irregular</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var duration = (item.EndDate - item.StartDate).TotalDays + 1;
                        var isIrregularPattern = duration > 5 || item.IsIrregular;
                        var statusClass = item.Status?.ToLower() switch
                        {
                            "approved" => "bg-success",
                            "pending" => "bg-warning",
                            "rejected" => "bg-danger",
                            "cancelled" => "bg-secondary",
                            _ => "bg-secondary"
                        };
                        <tr class="@(isIrregularPattern && item.IsIrregular ? "table-warning" : "")">
                            <td>
                                <strong>@item.EmployeeName</strong><br />
                                <small class="text-muted">ID: @item.EmployeeId</small>
                            </td>
                            <td>
                                <span class="badge bg-info">@item.LeaveType</span>
                            </td>
                            <td>@item.StartDate.ToString("MMM dd, yyyy")</td>
                            <td>@item.EndDate.ToString("MMM dd, yyyy")</td>
                            <td><strong>@item.TotalDays</strong> days</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Reason))
                                {
                                    <small title="@item.Reason">
                                        @(item.Reason.Length > 40 ? item.Reason.Substring(0, 40) + "..." : item.Reason)
                                    </small>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <span class="badge @statusClass">@(item.Status ?? "Pending")</span>
                            </td>
                            <td>
                                @if (item.IsIrregular)
                                {
                                    <span class="badge bg-danger">
                                        <i class="bi bi-exclamation-triangle"></i> Yes
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">No</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex flex-column gap-1">
                                    @if (item.Status?.ToLower() != "approved")
                                    {
                                        <form asp-action="Approve" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@item.RequestId" />
                                            <button type="submit" class="btn btn-success btn-sm w-100" 
                                                    title="Approve this leave request"
                                                    onclick="return confirm('Are you sure you want to approve this leave request?');">
                                                <i class="bi bi-check-circle"></i> Approve
                                            </button>
                                        </form>
                                    }
                                    @if (item.Status?.ToLower() != "rejected" && item.Status?.ToLower() != "cancelled")
                                    {
                                        <button type="button" class="btn btn-danger btn-sm w-100" 
                                                onclick="showRejectModal(@item.RequestId)" 
                                                title="Reject this leave request">
                                            <i class="bi bi-x-circle"></i> Reject
                                        </button>
                                    }
                                    @if (!item.IsIrregular)
                                    {
                                        <form asp-action="FlagIrregular" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@item.RequestId" />
                                            <button type="submit" class="btn btn-warning btn-sm w-100" 
                                                    title="Flag this leave request as irregular (will notify HR)"
                                                    onclick="return confirm('Flag this leave request as irregular? This will notify HR administrators.');">
                                                <i class="bi bi-flag"></i> Flag Irregular
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-warning btn-sm w-100" disabled title="Already flagged as irregular">
                                            <i class="bi bi-flag-fill"></i> Flagged Irregular
                                        </button>
                                    }
                                    <a asp-action="ViewLeaveRequest" asp-route-id="@item.RequestId" class="btn btn-info btn-sm w-100">
                                        <i class="bi bi-eye"></i> View Details
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <p class="text-muted">
                <small>Total Requests: <strong>@Model.Count()</strong></small>
            </p>
        </div>
    }
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Reject Leave Request</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Reject" method="post">
                <div class="modal-body">
                    <input type="hidden" name="id" id="rejectRequestId" />
                    <div class="mb-3">
                        <label for="rejectionReason" class="form-label">Rejection Reason <span class="text-danger">*</span></label>
                        <textarea name="rejectionReason" id="rejectionReason" class="form-control" rows="3" 
                                  placeholder="Please provide a reason for rejection..." required></textarea>
                        <small class="form-text text-muted">This reason will be visible to the employee.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Confirm Rejection</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function showRejectModal(requestId) {
        document.getElementById('rejectRequestId').value = requestId;
        document.getElementById('rejectionReason').value = '';
        var modal = new bootstrap.Modal(document.getElementById('rejectModal'));
        modal.show();
    }
</script>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Leave Types
    </a>
</div>
