@model IEnumerable<Milstone3_WebApp.Models.PendingLeaveDto>
@{
    ViewData["Title"] = "Pending approvals";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Pending leave approvals</h1>
        <p class="page-subtitle">@Model.Count() request(s) to review</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="AllLeaveRequests" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-list-ul me-1"></i>All requests
        </a>
        <a asp-action="IrregularLeaves" class="btn btn-outline-warning btn-sm">
            <i class="bi bi-exclamation-triangle me-1"></i>Irregular
        </a>
    </div>
</div>

<!-- Status filter -->
<div class="card mb-3">
    <div class="card-body" style="padding:12px 18px!important;">
        <form method="get" class="d-flex align-items-end gap-3">
            <div>
                <label class="form-label mb-1">Status</label>
                <select name="statusFilter" class="form-select" style="width:160px;" onchange="this.form.submit()">
                    <option value="">All statuses</option>
                    <option value="Pending"   selected="@(ViewBag.StatusFilter == "Pending"   ? "selected" : null)">Pending</option>
                    <option value="Approved"  selected="@(ViewBag.StatusFilter == "Approved"  ? "selected" : null)">Approved</option>
                    <option value="Rejected"  selected="@(ViewBag.StatusFilter == "Rejected"  ? "selected" : null)">Rejected</option>
                    <option value="Cancelled" selected="@(ViewBag.StatusFilter == "Cancelled" ? "selected" : null)">Cancelled</option>
                </select>
            </div>
            <a asp-action="Pending" class="btn btn-outline-secondary btn-sm">Clear</a>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="dt-controls px-4 pt-4 pb-2">
            <div class="dt-search">
                <i class="bi bi-search search-icon"></i>
                <input type="text" placeholder="Search…"
                       data-dt-search="pendingTable" data-dt-pagesize="15" />
            </div>
            <span class="fs-12 text-muted-custom" data-dt-info="pendingTable"></span>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5 px-4">
                <i class="bi bi-calendar-check" style="font-size:40px;color:var(--text-muted);display:block;margin-bottom:12px;"></i>
                <div class="fw-600 fs-13" style="color:var(--text-secondary);">No leave requests to review</div>
                <div class="fs-12 text-muted-custom">All caught up!</div>
            </div>
        }
        else
        {
            <div class="admin-table-wrap">
                <table class="admin-table" id="pendingTable">
                    <thead>
                        <tr>
                            <th data-sort>Employee</th>
                            <th>Leave type</th>
                            <th data-sort>Start</th>
                            <th data-sort>End</th>
                            <th>Days</th>
                            <th>Reason</th>
                            <th>Status</th>
                            <th>Irregular</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var duration = (item.EndDate - item.StartDate).TotalDays + 1;
                            bool flagged = item.IsIrregular || duration > 5;
                            var pc = (item.Status?.ToLower()) switch {
                                "approved"  => "pill-approved",
                                "rejected"  => "pill-rejected",
                                "cancelled" => "pill-inactive",
                                _           => "pill-pending"
                            };
                            <tr style="@(item.IsIrregular ? "background:rgba(245,158,11,.04);" : "")">
                                <td>
                                    <div class="fw-600">@item.EmployeeName</div>
                                    <div class="fs-12 text-muted-custom">ID: @item.EmployeeId</div>
                                </td>
                                <td><span class="pill pill-onleave">@item.LeaveType</span></td>
                                <td>@item.StartDate.ToString("dd MMM yyyy")</td>
                                <td>@item.EndDate.ToString("dd MMM yyyy")</td>
                                <td class="fw-600">@item.TotalDays d</td>
                                <td class="text-muted-custom fs-12" style="max-width:200px;white-space:normal;">
                                    @if (!string.IsNullOrEmpty(item.Reason))
                                    {
                                        @(item.Reason.Length > 60 ? item.Reason[..60] + "…" : item.Reason)
                                    }
                                    else { <text>—</text> }
                                </td>
                                <td><span class="pill @pc">@(item.Status ?? "Pending")</span></td>
                                <td>
                                    @if (item.IsIrregular)
                                    {
                                        <span class="pill pill-rejected">Irregular</span>
                                    }
                                    else { <span class="text-muted-custom">—</span> }
                                </td>
                                <td>
                                    <div class="d-flex flex-column gap-1" style="min-width:96px;">
                                        <a asp-action="ViewLeaveRequest" asp-route-id="@item.RequestId"
                                           class="btn btn-sm btn-outline-secondary">View</a>
                                        @if (item.Status?.ToLower() != "approved")
                                        {
                                            <form asp-action="Approve" method="post">
                                                <input type="hidden" name="id" value="@item.RequestId" />
                                                <button type="submit" class="btn btn-sm btn-outline-primary w-100">Approve</button>
                                            </form>
                                        }
                                        @if (item.Status?.ToLower() != "rejected" && item.Status?.ToLower() != "cancelled")
                                        {
                                            <button class="btn btn-sm btn-outline-danger"
                                                    onclick="showRejectModal(@item.RequestId)">Reject</button>
                                        }
                                        @if (!item.IsIrregular)
                                        {
                                            <form asp-action="FlagIrregular" method="post">
                                                <input type="hidden" name="id" value="@item.RequestId" />
                                                <button type="submit" class="btn btn-sm btn-outline-warning w-100">Flag</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="dt-pagination px-4 pb-3">
                <span class="fs-12 text-muted-custom" data-dt-info="pendingTable"></span>
                <div class="dt-page-btns" data-dt-pages="pendingTable"></div>
            </div>
        }
    </div>
</div>

<!-- Reject modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:12px;border-color:var(--border);">
            <div class="modal-header" style="border-color:var(--border);">
                <h5 class="modal-title fs-13 fw-600">Reject leave request</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Reject" method="post">
                <div class="modal-body">
                    <input type="hidden" name="id" id="rejectRequestId" />
                    <div class="mb-3">
                        <label class="form-label">Rejection reason <span class="text-danger">*</span></label>
                        <textarea name="rejectionReason" id="rejectionReason" class="form-control" rows="3"
                                  placeholder="Visible to the employee." required></textarea>
                    </div>
                </div>
                <div class="modal-footer" style="border-color:var(--border);">
                    <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger btn-sm">Confirm rejection</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
function showRejectModal(id) {
    document.getElementById('rejectRequestId').value = id;
    document.getElementById('rejectionReason').value = '';
    new bootstrap.Modal(document.getElementById('rejectModal')).show();
}
</script>
}
