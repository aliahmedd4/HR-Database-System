@model IEnumerable<Milstone3_WebApp.LeaveEntitlement>

@{
    ViewData["Title"] = "Manage Leave Entitlements";
}

<div class="welcome-banner mb-4">
    <h2>Manage Leave Entitlements</h2>
    <p>Assign or adjust leave entitlements for employees.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm p-4 mb-3">
    <h5>Assign New Leave Entitlement</h5>
    <form asp-action="AssignLeaveEntitlement" method="post" class="row g-3">
        <div class="col-md-3">
            <label for="employeeId" class="form-label">Employee</label>
            <select name="employeeId" id="employeeId" class="form-select" required>
                <option value="">Select Employee</option>
                @foreach (var emp in ViewBag.Employees as IEnumerable<Milstone3_WebApp.Employee>)
                {
                    <option value="@emp.EmployeeId">@emp.FullName (@emp.EmployeeCode)</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label for="leaveType" class="form-label">Leave Type</label>
            <input type="text" name="leaveType" id="leaveType" class="form-control" 
                   placeholder="e.g., Sick, Vacation, Maternity" required />
            <small class="form-text text-muted">Enter leave type name</small>
        </div>
        <div class="col-md-2">
            <label for="allocatedDays" class="form-label">Allocated Days</label>
            <input type="number" name="allocatedDays" id="allocatedDays" class="form-control" min="0" step="0.5" required />
        </div>
        <div class="col-md-2">
            <label for="year" class="form-label">Year</label>
            <input type="number" name="year" id="year" class="form-control" value="@DateTime.Now.Year" min="2020" max="2100" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-plus-circle"></i> Assign
            </button>
        </div>
    </form>
</div>

<div class="card shadow-sm p-4 mb-3">
    <h5>Filters</h5>
    <form method="get" class="row g-3">
        <div class="col-md-5">
            <label for="employeeId" class="form-label">Employee</label>
            <select name="employeeId" id="employeeId" class="form-select">
                <option value="">All Employees</option>
                @foreach (var emp in ViewBag.Employees as IEnumerable<Milstone3_WebApp.Employee>)
                {
                    <option value="@emp.EmployeeId" selected="@(ViewBag.EmployeeIdFilter == emp.EmployeeId)">@emp.FullName</option>
                }
            </select>
        </div>
        <div class="col-md-5">
            <label for="leaveTypeFilter" class="form-label">Leave Type</label>
            <input type="text" name="leaveTypeFilter" id="leaveTypeFilter" class="form-control" 
                   placeholder="Filter by leave type name" value="@ViewBag.LeaveTypeFilter" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary me-2">Filter</button>
            <a asp-action="ManageLeaveEntitlements" class="btn btn-secondary">Clear</a>
        </div>
    </form>
</div>

<div class="card shadow-sm p-4">
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No leave entitlements found.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Employee</th>
                        <th>Leave Type</th>
                        <th>Year</th>
                        <th>Allocated Days</th>
                        <th>Used Days</th>
                        <th>Balance Days</th>
                        <th>Carry Forward</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entitlement in Model)
                    {
                        <tr>
                            <td>
                                <strong>@(entitlement.Employee?.FullName ?? $"Employee #{entitlement.EmployeeId}")</strong><br />
                                <small class="text-muted">@(entitlement.Employee?.EmployeeCode ?? "")</small>
                            </td>
                            <td>
                                <span class="badge bg-info">@(entitlement.Leave?.LeaveType ?? "N/A")</span>
                            </td>
                            <td>@entitlement.Year</td>
                            <td><strong>@entitlement.AllocatedDays</strong></td>
                            <td>@entitlement.UsedDays</td>
                            <td>
                                <span class="badge @(entitlement.BalanceDays > 0 ? "bg-success" : "bg-danger")">
                                    @entitlement.BalanceDays
                                </span>
                            </td>
                            <td>@entitlement.CarryForwardDays</td>
                            <td>
                                <button type="button" class="btn btn-sm btn-warning" 
                                        onclick="showAdjustModal(@entitlement.EmployeeId, @entitlement.LeaveId, @entitlement.Year)">
                                    <i class="bi bi-pencil"></i> Adjust
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Adjust Modal -->
<div class="modal fade" id="adjustModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Adjust Leave Entitlement</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AdjustLeaveEntitlement" method="post">
                <div class="modal-body">
                    <input type="hidden" name="employeeId" id="adjEmployeeId" />
                    <input type="hidden" name="leaveId" id="adjLeaveId" />
                    <input type="hidden" name="year" id="adjYear" />
                    <div class="mb-3">
                        <label for="adjustment" class="form-label">Adjustment (positive to add, negative to subtract)</label>
                        <input type="number" name="adjustment" id="adjustment" class="form-control" step="0.5" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Adjust</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function showAdjustModal(employeeId, leaveId, year) {
        document.getElementById('adjEmployeeId').value = employeeId;
        document.getElementById('adjLeaveId').value = leaveId;
        document.getElementById('adjYear').value = year;
        var modal = new bootstrap.Modal(document.getElementById('adjustModal'));
        modal.show();
    }
</script>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Leave Types
    </a>
</div>

