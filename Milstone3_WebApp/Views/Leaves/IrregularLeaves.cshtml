@model IEnumerable<Milstone3_WebApp.LeaveRequest>

@{
    ViewData["Title"] = "Irregular Leave Patterns";
}

<div class="welcome-banner">
    <h2>Irregular Leave Patterns</h2>
    <p>Leave requests exceeding 5 consecutive days that require special attention.</p>
</div>

<div class="card shadow-sm p-4">
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No irregular leave patterns found.
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> 
            <strong>Note:</strong> These leave requests exceed 5 consecutive days and may require additional review.
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Employee</th>
                        <th>Leave Type</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Total Days</th>
                        <th>Reason</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var leave in Model)
                    {
                        var duration = (leave.EndDate.ToDateTime(TimeOnly.MinValue) - leave.StartDate.ToDateTime(TimeOnly.MinValue)).TotalDays + 1;
                        <tr class="@(duration > 5 ? "table-warning" : "")">
                            <td>
                                @if (leave.Employee != null)
                                {
                                    <strong>@leave.Employee.FullName</strong><br />
                                    <small class="text-muted">(@leave.Employee.EmployeeCode)</small>
                                }
                                else
                                {
                                    <span>Employee #@leave.EmployeeId</span>
                                }
                            </td>
                            <td>
                                @if (leave.Leave != null)
                                {
                                    <span class="badge bg-info">@(leave.Leave.LeaveDescription ?? leave.Leave.LeaveType)</span>
                                }
                                else
                                {
                                    <span class="text-muted">N/A</span>
                                }
                            </td>
                            <td>@leave.StartDate.ToString("MMM dd, yyyy")</td>
                            <td>@leave.EndDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <strong>@leave.TotalDays</strong> days
                                @if (duration > 5)
                                {
                                    <span class="badge bg-warning text-dark ms-1">
                                        <i class="bi bi-exclamation-triangle"></i> Irregular
                                    </span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(leave.Reason))
                                {
                                    <small title="@leave.Reason">
                                        @(leave.Reason.Length > 40 ? leave.Reason.Substring(0, 40) + "..." : leave.Reason)
                                    </small>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @{
                                    var statusClass = leave.Status?.ToLower() switch
                                    {
                                        "approved" => "bg-success",
                                        "pending" => "bg-warning",
                                        "rejected" => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @statusClass">@(leave.Status ?? "Unknown")</span>
                            </td>
                            <td>
                                @if (leave.Status == "Pending" || leave.Status == "Submitted" || leave.Status == null)
                                {
                                    <div class="d-flex flex-column gap-1">
                                        <form asp-action="Approve" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@leave.RequestId" />
                                            <button type="submit" class="btn btn-success btn-sm w-100">
                                                <i class="bi bi-check-circle"></i> Approve
                                            </button>
                                        </form>
                                        <button type="button" class="btn btn-danger btn-sm w-100" 
                                                onclick="showRejectModal(@leave.RequestId)">
                                            <i class="bi bi-x-circle"></i> Reject
                                        </button>
                                        @if (!leave.IsIrregular.HasValue || !leave.IsIrregular.Value)
                                        {
                                            <form asp-action="FlagIrregular" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@leave.RequestId" />
                                                <button type="submit" class="btn btn-warning btn-sm w-100">
                                                    <i class="bi bi-flag"></i> Flag Irregular
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <p class="text-muted">
                <small>Total Irregular Requests: <strong>@Model.Count()</strong></small>
            </p>
        </div>
    }
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Reject Leave Request</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="Reject" method="post">
                <div class="modal-body">
                    <input type="hidden" name="id" id="rejectRequestId" />
                    <div class="mb-3">
                        <label for="rejectionReason" class="form-label">Rejection Reason <span class="text-danger">*</span></label>
                        <textarea name="rejectionReason" id="rejectionReason" class="form-control" rows="3" 
                                  placeholder="Please provide a reason for rejection..." required></textarea>
                        <small class="form-text text-muted">This reason will be visible to the employee.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Confirm Rejection</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function showRejectModal(requestId) {
        document.getElementById('rejectRequestId').value = requestId;
        document.getElementById('rejectionReason').value = '';
        var modal = new bootstrap.Modal(document.getElementById('rejectModal'));
        modal.show();
    }
</script>

<div class="mt-3">
    <a asp-action="Pending" class="btn btn-primary">
        <i class="bi bi-arrow-left"></i> Back to Pending Leaves
    </a>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Leave Types
    </a>
</div>

