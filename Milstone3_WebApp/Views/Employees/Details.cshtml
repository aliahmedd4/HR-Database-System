@model Milstone3_WebApp.Employee

@{
    ViewData["Title"] = "Details";
}

<h1>Employee Details</h1>

<div>
    <h4>Employee</h4>
    <hr />
    <dl class="row">

        <dt class="col-sm-2">Employee Code</dt>
        <dd class="col-sm-10">@Model.EmployeeCode</dd>

        <dt class="col-sm-2">First Name</dt>
        <dd class="col-sm-10">@Model.FirstName</dd>

        <dt class="col-sm-2">Last Name</dt>
        <dd class="col-sm-10">@Model.LastName</dd>

        <dt class="col-sm-2">Full Name</dt>
        <dd class="col-sm-10">@Model.FullName</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>

        <dt class="col-sm-2">Phone</dt>
        <dd class="col-sm-10">@Model.Phone</dd>

        <dt class="col-sm-2">National ID</dt>
        <dd class="col-sm-10">@Model.NationalId</dd>

        <dt class="col-sm-2">Date of Birth</dt>
        <dd class="col-sm-10">@Model.DateOfBirth</dd>

        <dt class="col-sm-2">Country of Birth</dt>
        <dd class="col-sm-10">@Model.CountryOfBirth</dd>

        <dt class="col-sm-2">Hire Date</dt>
        <dd class="col-sm-10">@Model.HireDate</dd>

        <dt class="col-sm-2">Termination Date</dt>
        <dd class="col-sm-10">@Model.TerminationDate</dd>

        <dt class="col-sm-2">Manager ID</dt>
        <dd class="col-sm-10">@Model.ManagerId</dd>

        <dt class="col-sm-2">Base Salary</dt>
        <dd class="col-sm-10">@Model.BaseSalary</dd>

        <dt class="col-sm-2">Is Active</dt>
        <dd class="col-sm-10">@Model.IsActive</dd>

        <dt class="col-sm-2">Address</dt>
        <dd class="col-sm-10">@Model.Address</dd>

        <dt class="col-sm-2">Created At</dt>
        <dd class="col-sm-10">@Model.CreatedAt</dd>

        <dt class="col-sm-2">Updated At</dt>
        <dd class="col-sm-10">@Model.UpdatedAt</dd>

        <!-- Emergency Contact Information -->
        <dt class="col-sm-2">Emergency Contact Name</dt>
        <dd class="col-sm-10">@(Model.EmergencyContactName ?? "Not provided")</dd>

        <dt class="col-sm-2">Emergency Contact Phone</dt>
        <dd class="col-sm-10">@(Model.EmergencyContactPhone ?? "Not provided")</dd>

        <dt class="col-sm-2">Relationship</dt>
        <dd class="col-sm-10">@(Model.Relationship ?? "Not provided")</dd>

        <!-- FIXED: Show names instead of IDs -->

        <dt class="col-sm-2">Contract</dt>
        <dd class="col-sm-10">@Model.Contract?.ContractType</dd>

        <dt class="col-sm-2">Department</dt>
        <dd class="col-sm-10">@Model.Department?.DepartmentName</dd>

        <dt class="col-sm-2">Position</dt>
        <dd class="col-sm-10">@Model.Position?.PositionTitle</dd>

        <dt class="col-sm-2">Roles</dt>
        <dd class="col-sm-10">
            @{
                var employeeRoles = Model.EmployeeRoles?.Where(er => er.IsActive == true).ToList() ?? new List<EmployeeRole>();
            }
            @if (employeeRoles.Any())
            {
                foreach (var role in employeeRoles)
                {
                    <span class="badge bg-primary me-1">@role.Role?.RoleName</span>
                }
            }
            else
            {
                <span class="text-muted">No roles assigned</span>
            }
        </dd>

    </dl>
</div>

<div>
    @{
        var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
        var isOwnProfile = userEmail != null && userEmail.Equals(Model.Email, StringComparison.OrdinalIgnoreCase);
    }
    
    @if (isOwnProfile)
    {
        <a asp-action="EditMyProfile" class="btn btn-success">Edit My Profile</a>
        <span>|</span>
    }
    @if (User.IsInRole("SystemAdmin"))
    {
        <a asp-action="AssignRole" asp-route-id="@Model.EmployeeId" class="btn btn-warning">Assign Roles</a>
        <span>|</span>
    }
    @if (User.IsInRole("HRAdmin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.EmployeeId" class="btn btn-primary">Edit (HR Admin)</a>
        <span>|</span>
        <a asp-action="ManageProfileCompleteness" asp-route-id="@Model.EmployeeId" class="btn btn-info">Manage Completeness</a>
        <span>|</span>
    }
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
