@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "My notifications";
    int unread = (int)(ViewBag.UnreadCount ?? 0);
}

<div class="page-header">
    <div>
        <h1 class="page-title">My notifications</h1>
        <p class="page-subtitle">
            @if (unread > 0)
            {
                <span style="color:var(--danger);font-weight:600;">@unread unread</span>
                <text> — </text>
            }
            @(ViewBag.EmployeeName ?? "")
        </p>
    </div>
    @if (unread > 0)
    {
        <form asp-action="MarkAllAsRead" method="post">
            <button type="submit" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-check-all me-1"></i>Mark all as read
            </button>
        </form>
    }
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-bell-slash" style="font-size:40px;color:var(--text-muted);display:block;margin-bottom:12px;"></i>
            <div class="fw-600 fs-13" style="color:var(--text-secondary);">No notifications yet</div>
            <div class="fs-12 text-muted-custom">You're all caught up!</div>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            @foreach (var n in Model)
            {
                bool isRead = (bool)(n.IsRead ?? true);
                string typeIcon = (string)(n.NotificationType ?? "") switch {
                    "Leave"    => "bi-calendar-x",
                    "Payroll"  => "bi-cash-coin",
                    "Mission"  => "bi-briefcase",
                    "Shift"    => "bi-clock",
                    "Contract" => "bi-file-earmark-text",
                    _          => "bi-bell"
                };
                string priorityPill = (string)(n.Priority ?? "Normal") switch {
                    "High" or "Urgent" => "pill-rejected",
                    "Low"              => "pill-inactive",
                    _                  => "pill-onleave"
                };

                <div style="display:flex;align-items:flex-start;gap:14px;padding:16px 20px;
                             border-bottom:1px solid var(--border);
                             background:@(isRead ? "transparent" : "rgba(59,130,246,.03)");
                             border-left:@(isRead ? "3px solid transparent" : "3px solid var(--accent)");">

                    <div style="width:36px;height:36px;border-radius:9px;flex-shrink:0;
                                background:@(isRead ? "var(--bg)" : "var(--accent-light)");
                                color:@(isRead ? "var(--text-muted)" : "var(--accent)");
                                display:flex;align-items:center;justify-content:center;font-size:16px;">
                        <i class="bi @typeIcon"></i>
                    </div>

                    <div style="flex:1;min-width:0;">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <span class="fw-600 fs-13">@n.Title</span>
                            @if (!isRead)
                            {
                                <span class="pill pill-onleave" style="font-size:10px;padding:1px 7px;">New</span>
                            }
                            <span class="pill @priorityPill ms-auto" style="font-size:10px;padding:1px 7px;">@n.Priority</span>
                        </div>
                        <div class="fs-13 text-secondary-custom mb-1">@n.Message</div>
                        <div class="fs-12 text-muted-custom">
                            @(n.CreatedAt?.ToString("dd MMM yyyy, HH:mm") ?? "")
                        </div>
                    </div>

                    @if (!isRead)
                    {
                        <form asp-action="MarkAsRead" asp-route-id="@n.EmployeeNotificationId" method="post" style="flex-shrink:0;">
                            <button type="submit" class="btn btn-sm btn-outline-secondary" title="Mark as read">
                                <i class="bi bi-check"></i>
                            </button>
                        </form>
                    }
                </div>
            }
        </div>
    </div>
}
