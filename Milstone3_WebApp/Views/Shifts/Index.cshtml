@model IEnumerable<Milstone3_WebApp.ShiftSchedule>
@{
    ViewData["Title"] = "Shifts";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Shift management</h1>
        <p class="page-subtitle">@Model.Count() shift type(s) configured</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Assignments" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-calendar3-range me-1"></i>Assignments
        </a>
        <a asp-action="RotationalShifts" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-repeat me-1"></i>Rotational
        </a>
        @if (User.IsInRole("HRAdmin") || User.IsInRole("SystemAdmin"))
        {
            <a asp-action="CreateSplitShift" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-layout-split me-1"></i>Split shift
            </a>
        }
        @if (User.IsInRole("SystemAdmin"))
        {
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus me-1"></i>New shift
            </a>
        }
    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-calendar3" style="font-size:40px;color:var(--text-muted);display:block;margin-bottom:12px;"></i>
            <div class="fw-600 fs-13" style="color:var(--text-secondary);">No shifts configured yet</div>
            @if (User.IsInRole("SystemAdmin"))
            {
                <a asp-action="Create" class="btn btn-primary btn-sm mt-3">Create first shift</a>
            }
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var shift in Model)
        {
            <div class="col-md-4 col-lg-3">
                <div class="card h-100">
                    <div class="card-header">
                        <span class="card-title">@shift.Name</span>
                        <span class="pill @(shift.Status == "Active" ? "pill-active" : "pill-inactive")">
                            @shift.Status
                        </span>
                    </div>
                    <div class="card-body">
                        <dl style="display:grid;grid-template-columns:auto 1fr;gap:4px 12px;font-size:13px;margin:0;">
                            <dt class="text-muted-custom fw-500">Type</dt>
                            <dd class="mb-0">@(shift.Type ?? "Standard")</dd>
                            <dt class="text-muted-custom fw-500">Hours</dt>
                            <dd class="mb-0 fw-600">@shift.StartTime.ToString("HH:mm") – @shift.EndTime.ToString("HH:mm")</dd>
                            @if (shift.BreakDuration > 0)
                            {
                                <dt class="text-muted-custom fw-500">Break</dt>
                                <dd class="mb-0">@shift.BreakDuration min</dd>
                            }
                            @if (shift.GracePeriodMinutes > 0)
                            {
                                <dt class="text-muted-custom fw-500">Grace</dt>
                                <dd class="mb-0">@shift.GracePeriodMinutes min</dd>
                            }
                        </dl>
                    </div>
                    <div class="card-body pt-0">
                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@shift.ShiftId"
                               class="btn btn-sm btn-outline-secondary flex-fill">Details</a>
                            @if (User.IsInRole("SystemAdmin"))
                            {
                                <a asp-action="Edit" asp-route-id="@shift.ShiftId"
                                   class="btn btn-sm btn-outline-primary flex-fill">Edit</a>
                            }
                            @if (User.IsInRole("HRAdmin") || User.IsInRole("SystemAdmin"))
                            {
                                <a asp-action="AssignToEmployee" asp-route-id="@shift.ShiftId"
                                   class="btn btn-sm btn-outline-primary flex-fill">Assign</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
