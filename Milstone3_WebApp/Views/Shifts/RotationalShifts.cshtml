@model IEnumerable<Milstone3_WebApp.ShiftCycle>
@{
    ViewData["Title"] = "Rotational Shifts";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Rotational Shift Cycles</h2>
    @if (User.IsInRole("HRAdmin") || User.IsInRole("SystemAdmin"))
    {
        <a asp-action="CreateRotationalShift" class="btn btn-primary">Create Rotational Shift</a>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="row">
    @foreach (var cycle in Model)
    {
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">@cycle.CycleName</h5>
                </div>
                <div class="card-body">
                    <p><strong>Cycle Days:</strong> @cycle.CycleDays</p>
                    @if (!string.IsNullOrEmpty(cycle.Description))
                    {
                        <p><strong>Description:</strong> @cycle.Description</p>
                    }
                    <p><strong>Status:</strong> 
                        <span class="badge bg-@(cycle.IsActive == true ? "success" : "secondary")">
                            @(cycle.IsActive == true ? "Active" : "Inactive")
                        </span>
                    </p>
                    
                    <h6 class="mt-3">Shift Sequence:</h6>
                    <ul class="list-group">
                        @foreach (var assignment in cycle.ShiftCycleAssignments.OrderBy(sca => sca.DaySequence))
                        {
                            <li class="list-group-item">
                                Day @assignment.DaySequence: @assignment.Shift.Name 
                                (@assignment.Shift.StartTime.ToString("HH:mm") - @assignment.Shift.EndTime.ToString("HH:mm"))
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No rotational shifts found. @if (User.IsInRole("HRAdmin") || User.IsInRole("SystemAdmin")) { <a asp-action="CreateRotationalShift">Create your first rotational shift</a> }</div>
}

