<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — HRMS" : "HRMS")</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body class="admin-body" data-theme="dark">

    @await Html.PartialAsync("_Sidebar")

    <div class="admin-main" id="adminMain">

        @await Html.PartialAsync("_Topbar")

        <div class="admin-content">

            @* Toast mount point *@
            <div id="toastArea" class="toast-area"></div>

            @* Hidden TempData carriers — admin.js picks these up on load *@
            @if (TempData["SuccessMessage"] != null)
            {
                <span id="tempSuccess" class="d-none">@TempData["SuccessMessage"]</span>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <span id="tempError" class="d-none">@TempData["ErrorMessage"]</span>
            }

            @* Inline ViewBag error (forms) *@
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger d-flex align-items-center gap-2 mb-3" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span>@ViewBag.Error</span>
                </div>
            }

            @RenderBody()

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>
