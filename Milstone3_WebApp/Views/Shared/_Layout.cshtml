<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Milstone3_WebApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Milstone3_WebApp.styles.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Portal Banner -->
    <header class="welcome-banner">
        <div class="container-fluid">
            <h1 class="portal-title">Milstone3 HRMS Portal</h1>
            <p class="portal-subtitle">Manage Employees, Leaves, Missions, Payrolls & Notifications</p>
        </div>
    </header>

    <!-- Navigation -->
    <nav class="navbar navbar-expand-sm navbar-dark bg-dark mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">Dashboard</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-controller="Employees" asp-action="Index">Employees</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Attendance" asp-action="Index">Attendance</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Shifts" asp-action="Index">Shifts</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Leaves" asp-action="Index">Leaves</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Missions" asp-action="Index">Missions</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Payrolls" asp-action="Index">Payrolls</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Notifications" asp-action="Index">Notifications</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Contracts" asp-action="Index">Contracts</a></li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a></li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-outline-danger btn-sm text-white ms-2" asp-controller="Account" asp-action="Logout" style="border-color: #dc3545;">
                            🚪 Logout
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Footer -->
    <footer class="border-top footer text-muted mt-4">
        <div class="container text-center">
            &copy; 2025 - Milstone3_WebApp | <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
