@{
    ViewData["Title"] = "Access Denied";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow border-warning">
            <div class="card-body text-center p-5">
                <div class="mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="text-warning" viewBox="0 0 16 16">
                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z" />
                        <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z" />
                    </svg>
                </div>

                <h2 class="text-danger mb-3">Access Denied</h2>
                <p class="lead mb-4">You don't have permission to access this page.</p>
                <p class="text-muted">This page requires specific role permissions. Please contact your administrator if you believe you should have access.</p>

                <div class="mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary me-2">Go to Home</a>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-secondary">Logout</a>
                </div>
            </div>
        </div>
    </div>
</div>