@{
    ViewData["Title"] = "First-run setup";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Setup — HRMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root {
            color-scheme: dark;
            --accent: #2f7fe0; --bg: #1a1a1a; --surface: #1e1e1e;
            --border: #2e2e2e; --text-primary: #f5f5f5; --text-muted: #a3a3a3;
        }
        body { margin:0; min-height:100vh; display:flex; align-items:center; justify-content:center;
               background:var(--bg); color:var(--text-primary);
               font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif; font-size:14px; }
        .card { background:var(--surface); border:1px solid var(--border); border-radius:14px;
                padding:36px 40px; width:100%; max-width:420px; }
        .badge-setup { display:inline-flex; align-items:center; gap:6px; background:#3a2e14;
                       color:#e0a030; border-radius:20px; padding:3px 10px; font-size:11px;
                       font-weight:600; margin-bottom:16px; }
        h2 { font-size:20px; font-weight:700; margin:0 0 4px; }
        p.sub { font-size:13px; color:var(--text-muted); margin:0 0 24px; }
        label { display:block; font-size:12px; font-weight:600; color:var(--text-muted); margin-bottom:4px; }
        .iw { position:relative; margin-bottom:16px; }
        .iw i { position:absolute; left:11px; top:50%; transform:translateY(-50%); color:#6b6b6b; font-size:14px; pointer-events:none; }
        input { width:100%; padding:9px 12px 9px 34px; background:#242424; border:1px solid var(--border);
                border-radius:8px; color:var(--text-primary); font-size:13px; outline:none; box-sizing:border-box; }
        input:focus { border-color:var(--accent); box-shadow:0 0 0 3px rgba(47,127,224,.12); }
        .btn { width:100%; background:var(--accent); color:#fff; border:none; border-radius:8px;
               padding:10px; font-size:14px; font-weight:600; cursor:pointer; margin-top:4px; }
        .btn:hover { background:#2468c4; }
        .err { background:#2d1515; border:1px solid #5c2020; border-radius:8px;
               padding:10px 14px; font-size:13px; color:#e05252; margin-bottom:16px;
               display:flex; gap:8px; align-items:flex-start; }
        .info { background:#162820; border:1px solid #1e4030; border-radius:8px;
                padding:12px 14px; font-size:12px; color:#4caf50; margin-top:20px; line-height:1.6; }
    </style>
</head>
<body>
<div class="card">
    <span class="badge-setup"><i class="bi bi-wrench-adjustable"></i> First-run setup</span>
    <h2>Create your admin account</h2>
    <p class="sub">This page is only available once — it locks as soon as the first password is set.</p>

    @if (ViewBag.Error != null)
    {
        <div class="err"><i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error</div>
    }

    <form method="post" asp-action="Setup">
        @Html.AntiForgeryToken()
        <label>Email address of an existing employee</label>
        <div class="iw">
            <i class="bi bi-envelope"></i>
            <input type="email" name="email" required placeholder="ahmed.ali@company.com" autocomplete="off" />
        </div>
        <label>Password</label>
        <div class="iw">
            <i class="bi bi-lock"></i>
            <input type="password" name="password" required minlength="8" placeholder="Min 8 characters" />
        </div>
        <label>Confirm password</label>
        <div class="iw">
            <i class="bi bi-lock-fill"></i>
            <input type="password" name="confirmPassword" required minlength="8" placeholder="Repeat password" />
        </div>
        <button type="submit" class="btn">Create admin account</button>
    </form>

    <div class="info">
        <strong>Seeded employees you can use:</strong><br>
        ahmed.ali@company.com &nbsp;·&nbsp; mohamed.hassan@company.com<br>
        sara.ibrahim@company.com &nbsp;·&nbsp; fatima.mahmoud@company.com<br>
        omar.khalil@company.com &nbsp;·&nbsp; layla.youssef@company.com<br><br>
        After setup, sign in and use <strong>Create account</strong> to add passwords for other roles.
    </div>
</div>
</body>
</html>
