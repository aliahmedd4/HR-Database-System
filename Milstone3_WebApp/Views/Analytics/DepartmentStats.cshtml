@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Department stats";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Department statistics</h1>
        <p class="page-subtitle">Headcount and workforce breakdown by department</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="ComplianceReport" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-shield-check me-1"></i>Compliance
        </a>
        <a asp-action="DiversityReport" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-pie-chart me-1"></i>Diversity
        </a>
    </div>
</div>

@{
    var stats = Model?.ToList() ?? new List<dynamic>();
    int grandTotal = 0;
    foreach (var s in stats) { try { grandTotal += (int)s.EmployeeCount; } catch { } }
}

<!-- Summary stat card -->
@if (stats.Any())
{
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-sm-6">
            <div class="stat-card accent">
                <div class="stat-icon"><i class="bi bi-building"></i></div>
                <div class="stat-label">Departments</div>
                <div class="stat-value">@stats.Count</div>
            </div>
        </div>
        <div class="col-md-3 col-sm-6">
            <div class="stat-card success">
                <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
                <div class="stat-label">Total headcount</div>
                <div class="stat-value">@grandTotal</div>
            </div>
        </div>
    </div>
}

<div class="card">
    <div class="card-header">
        <span class="card-title">Headcount by department</span>
    </div>
    <div class="card-body p-0">
        <div class="dt-controls px-4 pt-4 pb-2">
            <div class="dt-search">
                <i class="bi bi-search search-icon"></i>
                <input type="text" placeholder="Search departments…"
                       data-dt-search="deptTable" data-dt-pagesize="20" />
            </div>
        </div>

        <div class="admin-table-wrap">
            <table class="admin-table" id="deptTable">
                <thead>
                    <tr>
                        <th data-sort>Department</th>
                        <th data-sort>Employees</th>
                        <th>Share</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in stats)
                    {
                        int count = 0;
                        try { count = (int)s.EmployeeCount; } catch { }
                        double share = grandTotal > 0 ? Math.Round((double)count / grandTotal * 100, 1) : 0;
                        <tr>
                            <td class="fw-600">@s.DepartmentName</td>
                            <td>@count</td>
                            <td style="min-width:160px;">
                                <div class="d-flex align-items-center gap-2">
                                    <div style="flex:1;background:var(--border);border-radius:4px;height:6px;">
                                        <div style="background:var(--accent);width:@(share)%;height:6px;border-radius:4px;"></div>
                                    </div>
                                    <span class="fs-12 text-muted-custom" style="width:36px;text-align:right;">@share%</span>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!stats.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted-custom">No data available.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="dt-pagination px-4 pb-3">
            <span class="fs-12 text-muted-custom" data-dt-info="deptTable"></span>
            <div class="dt-page-btns" data-dt-pages="deptTable"></div>
        </div>
    </div>
</div>
