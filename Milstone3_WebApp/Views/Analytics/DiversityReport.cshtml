@{
    ViewData["Title"] = "Diversity Report";
}

<div class="welcome-banner">
    <h2>Diversity Report</h2>
    <p>Comprehensive diversity statistics across the organization.</p>
</div>

<!-- Search Form -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-action="DiversityReport" class="row g-3">
            <div class="col-md-4">
                <label for="searchTerm" class="form-label">Search</label>
                <input type="text" name="searchTerm" id="searchTerm"
                       value="@ViewBag.SearchTerm"
                       placeholder="Search by name, email, country, or department"
                       class="form-control" />
            </div>
            <div class="col-md-3">
                <label for="filterBy" class="form-label">Filter By</label>
                <select name="filterBy" id="filterBy" class="form-select">
                    <option value="">All Fields</option>
                    <option value="name" selected="@(ViewBag.FilterBy?.ToString() == "name")">Name</option>
                    <option value="country" selected="@(ViewBag.FilterBy?.ToString() == "country")">Country</option>
                    <option value="department" selected="@(ViewBag.FilterBy?.ToString() == "department")">Department</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary me-2">Search</button>
                <a asp-action="DiversityReport" class="btn btn-secondary">Clear</a>
            </div>
        </form>
        @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
        {
            <div class="mt-2">
                <small class="text-muted">Showing results for: <strong>@ViewBag.SearchTerm</strong></small>
            </div>
        }
    </div>
</div>

<div class="card">
    <h3>Diversity by Country/Nationality</h3>
    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Country/Nationality</th>
                    <th>Employee Count</th>
                    <th>Percentage</th>
                    <th>Departments</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.DiversityByCountry != null)
                {
                    @foreach (var item in ViewBag.DiversityByCountry)
                    {
                        <tr>
                            <td>@item.Country</td>
                            <td>@item.Count</td>
                            <td>@item.Percentage.ToString("F2")%</td>
                            <td>@string.Join(", ", item.Departments)</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center">No diversity data available.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card mt-4">
    <h3>Diversity by Department</h3>
    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Department</th>
                    <th>Total Employees</th>
                    <th>Number of Countries Represented</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.DiversityByDepartment != null)
                {
                    @foreach (var item in ViewBag.DiversityByDepartment)
                    {
                        <tr>
                            <td>@item.Department</td>
                            <td>@item.TotalEmployees</td>
                            <td>@item.Countries</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center">No department diversity data available.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="card mt-4">
    <div class="row">
        <div class="col-md-6">
            <h4>Summary</h4>
            <p><strong>Total Employees:</strong> @ViewBag.TotalEmployees</p>
            <p><strong>Total Countries Represented:</strong> @(ViewBag.DiversityByCountry != null ? ViewBag.DiversityByCountry.Count : 0)</p>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="ComplianceReport" class="btn btn-secondary">Back to Compliance Report</a>
    <a asp-action="DepartmentStats" class="btn btn-primary">View Department Statistics</a>
</div>

