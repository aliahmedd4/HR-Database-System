@model IEnumerable<Milstone3_WebApp.Attendance>
@{
    ViewData["Title"] = "My Attendance";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Attendance Records</h2>
    <div>
        <a asp-action="Record" class="btn btn-primary">Record Attendance</a>
        <a asp-action="RequestCorrection" class="btn btn-outline-secondary">Request Correction</a>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label for="date" class="form-label">View Date</label>
                <input type="date" class="form-control" name="date" value="@ViewBag.CurrentDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4">
                <label class="form-label">&nbsp;</label>
                <button type="submit" class="btn btn-primary d-block">Filter</button>
            </div>
        </form>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Date</th>
                <th>Shift</th>
                <th>Check-In</th>
                <th>Check-Out</th>
                <th>Hours Worked</th>
                <th>Overtime</th>
                <th>Lateness</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.AttendanceDate.ToString("MMM dd, yyyy")</td>
                    <td>@(item.Shift?.Name ?? "N/A")</td>
                    <td>@(item.EntryTime?.ToString("HH:mm") ?? "-")</td>
                    <td>@(item.ExitTime?.ToString("HH:mm") ?? "-")</td>
                    <td>@(item.HoursWorked?.ToString("F2") ?? "0.00") hrs</td>
                    <td>@(item.OvertimeHours?.ToString("F2") ?? "0.00") hrs</td>
                    <td>
                        @if (item.LatenessMinutes > 0)
                        {
                            <span class="text-warning">@item.LatenessMinutes mins</span>
                        }
                        else
                        {
                            <span class="text-success">On Time</span>
                        }
                    </td>
                    <td>
                        <span class="badge bg-@(item.Status == "Present" ? "success" : item.Status == "On Leave" ? "info" : "danger")">
                            @item.Status
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No attendance records found for the selected period.</div>
}

