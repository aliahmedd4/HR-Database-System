@model IEnumerable<Milstone3_WebApp.Attendance>
@{
    ViewData["Title"] = "Attendance";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Attendance records</h1>
        <p class="page-subtitle">@(ViewBag.CurrentDate?.ToString("MMMM yyyy") ?? "Current period")</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Record" class="btn btn-primary btn-sm">
            <i class="bi bi-box-arrow-in-right me-1"></i>Record attendance
        </a>
        <a asp-action="RequestCorrection" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-pencil me-1"></i>Request correction
        </a>
    </div>
</div>

<!-- Date filter -->
<div class="card mb-3">
    <div class="card-body" style="padding:14px 18px!important;">
        <form method="get" class="d-flex align-items-end gap-3">
            <div>
                <label class="form-label mb-1">View date</label>
                <input type="date" class="form-control" name="date"
                       value="@(ViewBag.CurrentDate != null ? ((DateTime)ViewBag.CurrentDate).ToString("yyyy-MM-dd") : DateTime.Today.ToString("yyyy-MM-dd"))" />
            </div>
            <button type="submit" class="btn btn-primary btn-sm">Filter</button>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="dt-controls px-4 pt-4 pb-2">
            <div class="dt-search">
                <i class="bi bi-search search-icon"></i>
                <input type="text" placeholder="Search records…"
                       data-dt-search="attendanceTable" data-dt-pagesize="20" />
            </div>
            <span class="fs-12 text-muted-custom" data-dt-info="attendanceTable"></span>
        </div>

        <div class="admin-table-wrap">
            <table class="admin-table" id="attendanceTable">
                <thead>
                    <tr>
                        <th data-sort>Date</th>
                        <th>Shift</th>
                        <th>Check-in</th>
                        <th>Check-out</th>
                        <th>Hours worked</th>
                        <th>Overtime</th>
                        <th>Lateness</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-600">@item.AttendanceDate.ToString("dd MMM yyyy")</td>
                            <td class="text-muted-custom">@(item.Shift?.Name ?? "—")</td>
                            <td>@(item.EntryTime?.ToString("HH:mm") ?? "—")</td>
                            <td>@(item.ExitTime?.ToString("HH:mm") ?? "—")</td>
                            <td>@(item.HoursWorked?.ToString("F1") ?? "0.0") h</td>
                            <td>
                                @if (item.OvertimeHours > 0)
                                {
                                    <span class="text-accent fw-600">+@(item.OvertimeHours?.ToString("F1")) h</span>
                                }
                                else { <span class="text-muted-custom">—</span> }
                            </td>
                            <td>
                                @if (item.LatenessMinutes > 0)
                                {
                                    <span style="color:var(--warning);font-weight:600;">@item.LatenessMinutes min</span>
                                }
                                else { <span style="color:var(--success);">On time</span> }
                            </td>
                            <td>
                                @{
                                    var s = item.Status?.ToLower();
                                    var pillClass = s == "present" ? "pill-present"
                                                  : s == "onleave" || s == "on leave" ? "pill-onleave"
                                                  : "pill-absent";
                                }
                                <span class="pill @pillClass">@item.Status</span>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted-custom">
                                No attendance records for this period.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="dt-pagination px-4 pb-3">
            <span class="fs-12 text-muted-custom" data-dt-info="attendanceTable"></span>
            <div class="dt-page-btns" data-dt-pages="attendanceTable"></div>
        </div>
    </div>
</div>
