@{
    ViewData["Title"] = "Record attendance";
    var employee       = ViewBag.Employee as Milstone3_WebApp.Employee;
    var todayAttendance = ViewBag.TodayAttendance as Milstone3_WebApp.Attendance;
    var activeShift    = ViewBag.ActiveShift as Milstone3_WebApp.ShiftSchedule;
    var today          = (DateTime)ViewBag.Today;
    bool checkedIn     = todayAttendance?.EntryTime != null;
    bool checkedOut    = todayAttendance?.ExitTime  != null;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Record attendance</h1>
        <p class="page-subtitle">@today.ToString("dddd, d MMMM yyyy")</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-clock-history me-1"></i>All records
    </a>
</div>

<div class="row g-3 justify-content-center">
    <div class="col-lg-7">

        <!-- Employee / shift info -->
        <div class="card mb-3">
            <div class="card-body" style="padding:14px 18px!important;">
                <div class="d-flex align-items-center gap-3">
                    <div style="width:42px;height:42px;border-radius:50%;background:var(--accent-light);
                                color:var(--accent);display:flex;align-items:center;justify-content:center;
                                font-size:14px;font-weight:700;flex-shrink:0;">
                        @(string.Concat((employee?.FullName ?? "?").Split(' ').Take(2).Select(w => char.ToUpper(w[0]))))
                    </div>
                    <div>
                        <div class="fw-600 fs-13">@(employee?.FullName ?? "—")</div>
                        @if (activeShift != null)
                        {
                            <div class="fs-12 text-muted-custom">
                                @activeShift.Name &nbsp;·&nbsp;
                                @activeShift.StartTime.ToString("HH:mm") – @activeShift.EndTime.ToString("HH:mm")
                                @if (activeShift.GracePeriodMinutes > 0)
                                {
                                    <text>&nbsp;·&nbsp; @activeShift.GracePeriodMinutes min grace</text>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="fs-12 text-muted-custom">No shift assigned</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Offline alert (injected by JS) -->
        <div id="offlineAlert"></div>

        <!-- Check-in / Check-out cards -->
        <div class="row g-3 mb-3">

            <!-- Check-In -->
            <div class="col-6">
                <div class="card h-100" style="border-top:3px solid @(checkedIn ? "var(--success)" : "var(--border)");">
                    <div class="card-body text-center py-4">
                        <div class="fs-12 text-muted-custom mb-2 text-uppercase fw-600 tracking-wide">Check-in</div>
                        @if (checkedIn)
                        {
                            <div style="font-size:28px;font-weight:700;color:var(--success);line-height:1;">
                                @todayAttendance!.EntryTime!.Value.ToString("HH:mm")
                            </div>
                            <div class="fs-12 text-muted-custom mt-1">@todayAttendance.LoginMethod</div>
                        }
                        else
                        {
                            <div class="text-muted-custom fs-13 mb-3">Not checked in</div>
                            <form method="post" asp-action="Record" id="checkInForm">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="action" value="CheckIn" />
                                <select name="loginMethod" class="form-select form-select-sm mb-2">
                                    <option value="Web">Web portal</option>
                                    <option value="Mobile">Mobile app</option>
                                    <option value="Biometric">Biometric</option>
                                    <option value="Card">Card swipe</option>
                                </select>
                                <button type="submit" class="btn btn-primary btn-sm w-100">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Check in
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>

            <!-- Check-Out -->
            <div class="col-6">
                <div class="card h-100" style="border-top:3px solid @(checkedOut ? "var(--success)" : "var(--border)");">
                    <div class="card-body text-center py-4">
                        <div class="fs-12 text-muted-custom mb-2 text-uppercase fw-600 tracking-wide">Check-out</div>
                        @if (checkedOut)
                        {
                            <div style="font-size:28px;font-weight:700;color:var(--success);line-height:1;">
                                @todayAttendance!.ExitTime!.Value.ToString("HH:mm")
                            </div>
                            <div class="fs-12 text-muted-custom mt-1">@todayAttendance.LogoutMethod</div>
                        }
                        else if (checkedIn)
                        {
                            <div class="text-muted-custom fs-13 mb-3">Not checked out</div>
                            <form method="post" asp-action="Record" id="checkOutForm">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="action" value="CheckOut" />
                                <select name="logoutMethod" class="form-select form-select-sm mb-2">
                                    <option value="Web">Web portal</option>
                                    <option value="Mobile">Mobile app</option>
                                    <option value="Biometric">Biometric</option>
                                    <option value="Card">Card swipe</option>
                                </select>
                                <button type="submit" class="btn btn-danger btn-sm w-100">
                                    <i class="bi bi-box-arrow-left me-1"></i>Check out
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="text-muted-custom fs-13">Check in first</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Today's summary -->
        @if (todayAttendance != null)
        {
            <div class="card">
                <div class="card-header"><span class="card-title">Today's summary</span></div>
                <div class="card-body">
                    <div class="row g-3 text-center">
                        <div class="col-4">
                            <div class="fs-12 text-muted-custom mb-1">Hours worked</div>
                            <div class="fw-600 fs-13">@(todayAttendance.HoursWorked?.ToString("F1") ?? "0.0") h</div>
                        </div>
                        <div class="col-4">
                            <div class="fs-12 text-muted-custom mb-1">Overtime</div>
                            <div class="fw-600 fs-13" style="color:var(--accent);">
                                +@(todayAttendance.OvertimeHours?.ToString("F1") ?? "0.0") h
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="fs-12 text-muted-custom mb-1">Lateness</div>
                            @if (todayAttendance.LatenessMinutes > 0)
                            {
                                <div class="fw-600 fs-13" style="color:var(--warning);">@todayAttendance.LatenessMinutes min</div>
                            }
                            else
                            {
                                <div class="fw-600 fs-13" style="color:var(--success);">On time</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
<script src="~/js/attendance-offline.js" asp-append-version="true"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    if (window.AttendanceOffline && !window.AttendanceOffline.isOnline()) {
        var alert = document.createElement('div');
        alert.className = 'alert alert-warning mb-3';
        alert.innerHTML = '<i class="bi bi-wifi-off me-2"></i><strong>Offline mode:</strong> Attendance will be saved locally and synced when you reconnect.';
        document.getElementById('offlineAlert').appendChild(alert);
    }

    var checkInForm  = document.getElementById('checkInForm');
    var checkOutForm = document.getElementById('checkOutForm');

    if (checkInForm) {
        checkInForm.addEventListener('submit', function (e) {
            if (window.AttendanceOffline && !window.AttendanceOffline.isOnline()) {
                e.preventDefault();
                window.AttendanceOffline.record('CheckIn', this.querySelector('[name=loginMethod]').value, null);
            }
        });
    }
    if (checkOutForm) {
        checkOutForm.addEventListener('submit', function (e) {
            if (window.AttendanceOffline && !window.AttendanceOffline.isOnline()) {
                e.preventDefault();
                window.AttendanceOffline.record('CheckOut', null, this.querySelector('[name=logoutMethod]').value);
            }
        });
    }
});
</script>
}
