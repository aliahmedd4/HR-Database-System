@model Milstone3_WebApp.Mission
@{
    ViewData["Title"] = "Approve Mission";
}

<div class="welcome-banner mb-4">
    <h2>Approve Mission</h2>
    <p>Review the mission details and approve the request</p>
</div>

<div class="card">
    <div class="card-header bg-success text-white">
        <h5 class="mb-0">Mission Details</h5>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Mission Name:</dt>
            <dd class="col-sm-8">@Model.MissionName</dd>

            <dt class="col-sm-4">Employee:</dt>
            <dd class="col-sm-8">@(Model.Employee?.FullName ?? "N/A")</dd>

            <dt class="col-sm-4">Destination:</dt>
            <dd class="col-sm-8">@Model.Destination</dd>

            <dt class="col-sm-4">Location:</dt>
            <dd class="col-sm-8">@Model.Location</dd>

            <dt class="col-sm-4">Start Date:</dt>
            <dd class="col-sm-8">@Model.StartDate.ToString("yyyy-MM-dd")</dd>

            <dt class="col-sm-4">End Date:</dt>
            <dd class="col-sm-8">@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("yyyy-MM-dd") : "Not set")</dd>

            <dt class="col-sm-4">Status:</dt>
            <dd class="col-sm-8"><span class="badge bg-warning">@Model.Status</span></dd>
        </dl>
    </div>
</div>

<div class="card mt-3">
    <div class="card-body">
        <form asp-action="Approve" method="post">
            <input type="hidden" asp-for="MissionId" />
            
            <div class="form-group mb-3">
                <label for="remarks" class="form-label">Approval Remarks (Optional)</label>
                <textarea name="remarks" id="remarks" class="form-control" rows="3" placeholder="Add any notes or remarks about this approval..."></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    ✓ Approve Mission
                </button>
                <a asp-action="PendingApprovals" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

