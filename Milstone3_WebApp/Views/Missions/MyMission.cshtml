@model IEnumerable<Milstone3_WebApp.Mission>
@{
    ViewData["Title"] = "My missions";
}

<div class="page-header">
    <div>
        <h1 class="page-title">My missions</h1>
        <p class="page-subtitle">
            @if (!string.IsNullOrEmpty(ViewBag.EmployeeName as string))
            {
                <text>Assigned to @ViewBag.EmployeeName</text>
            }
        </p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-briefcase" style="font-size:40px;color:var(--text-muted);display:block;margin-bottom:12px;"></i>
            <div class="fw-600 fs-13" style="color:var(--text-secondary);">No missions assigned yet</div>
            <div class="fs-12 text-muted-custom">You'll see your missions here once a manager assigns one.</div>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var m in Model)
        {
            var duration = m.EndDate.HasValue
                ? m.EndDate.Value.DayNumber - m.StartDate.DayNumber + 1 : 0;

            var accentColor = m.Status switch {
                "Completed"  => "var(--success)",
                "InProgress" => "var(--accent)",
                "Assigned"   => "var(--warning)",
                "Cancelled"  => "var(--danger)",
                _            => "var(--text-muted)"
            };
            var pillClass = m.Status switch {
                "Completed"  => "pill-approved",
                "InProgress" => "pill-onleave",
                "Assigned"   => "pill-pending",
                "Cancelled"  => "pill-rejected",
                _            => "pill-inactive"
            };

            <div class="col-md-6 col-lg-4">
                <div class="card h-100" style="border-top:3px solid @accentColor;">
                    <div class="card-header">
                        <span class="card-title">@m.MissionName</span>
                        <span class="pill @pillClass">@m.Status</span>
                    </div>
                    <div class="card-body">
                        <dl style="display:grid;grid-template-columns:auto 1fr;gap:5px 12px;font-size:13px;margin:0;">
                            @if (!string.IsNullOrEmpty(m.Destination))
                            {
                                <dt class="text-muted-custom">Destination</dt>
                                <dd class="mb-0">@m.Destination</dd>
                            }
                            @if (!string.IsNullOrEmpty(m.Location))
                            {
                                <dt class="text-muted-custom">Location</dt>
                                <dd class="mb-0">@m.Location</dd>
                            }
                            <dt class="text-muted-custom">Start</dt>
                            <dd class="mb-0">@m.StartDate.ToString("dd MMM yyyy")</dd>
                            <dt class="text-muted-custom">End</dt>
                            <dd class="mb-0">@(m.EndDate?.ToString("dd MMM yyyy") ?? "—")</dd>
                            @if (duration > 0)
                            {
                                <dt class="text-muted-custom">Duration</dt>
                                <dd class="mb-0">@duration day(s)</dd>
                            }
                            @if (m.Manager != null)
                            {
                                <dt class="text-muted-custom">Manager</dt>
                                <dd class="mb-0">@m.Manager.FullName</dd>
                            }
                            @if (m.AssignedByNavigation != null)
                            {
                                <dt class="text-muted-custom">Assigned by</dt>
                                <dd class="mb-0">@m.AssignedByNavigation.FullName</dd>
                            }
                            @if (m.CompletedAt != null)
                            {
                                <dt class="text-muted-custom">Completed</dt>
                                <dd class="mb-0" style="color:var(--success);">@m.CompletedAt?.ToString("dd MMM yyyy HH:mm")</dd>
                            }
                        </dl>
                    </div>
                    <div class="card-body pt-0">
                        <a asp-action="Details" asp-route-id="@m.MissionId"
                           class="btn btn-sm btn-outline-secondary w-100">View details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
