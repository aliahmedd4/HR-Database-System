@model IEnumerable<Milstone3_WebApp.Mission>
@{
    ViewData["Title"] = "Pending Mission Approvals";
}

<div class="welcome-banner mb-4">
    <h2>Pending Mission Approvals</h2>
    <p>Review and approve or reject mission requests assigned to your team, @ViewBag.ManagerName</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        <h4>No Pending Approvals</h4>
        <p>There are no missions pending your approval at the moment.</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var mission in Model)
        {
            var duration = mission.EndDate.HasValue
                ? mission.EndDate.Value.DayNumber - mission.StartDate.DayNumber + 1
                : 0;

            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card shadow-sm h-100 border-warning" style="border-width: 3px;">
                    <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">@mission.MissionName</h5>
                        <span class="badge bg-warning text-dark">⏳ Pending</span>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <strong>👤 Employee:</strong> @(mission.Employee?.FullName ?? "N/A")<br>
                            <strong>📍 Destination:</strong> @mission.Destination<br>
                            <strong>🌍 Location:</strong> @mission.Location
                        </div>

                        <div class="mb-3">
                            <strong>📅 Start Date:</strong> @mission.StartDate.ToString("yyyy-MM-dd")<br>
                            <strong>📅 End Date:</strong> @(mission.EndDate.HasValue ? mission.EndDate.Value.ToString("yyyy-MM-dd") : "Not set")<br>
                            <strong>⏱️ Duration:</strong> @duration days
                        </div>

                        @if (mission.AssignedByNavigation != null)
                        {
                            <div class="mb-2">
                                <small class="text-muted">
                                    Assigned by: @mission.AssignedByNavigation.FullName
                                </small>
                            </div>
                        }

                        <div class="alert alert-warning mb-0 py-2">
                            <small><strong>Status:</strong> @mission.Status</small>
                        </div>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a asp-action="Approve" asp-route-id="@mission.MissionId" class="btn btn-success btn-sm flex-fill">
                            ✓ Approve
                        </a>
                        <a asp-action="Reject" asp-route-id="@mission.MissionId" class="btn btn-danger btn-sm flex-fill">
                            ✗ Reject
                        </a>
                        <a asp-action="Details" asp-route-id="@mission.MissionId" class="btn btn-info btn-sm">
                            View
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mt-4">
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
        ← Back to Dashboard
    </a>
</div>

