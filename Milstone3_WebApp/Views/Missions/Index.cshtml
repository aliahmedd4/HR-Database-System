@model IEnumerable<Milstone3_WebApp.Mission>

@{
    ViewData["Title"] = "All Missions";
}

<div class="welcome-banner">
    <h2>All Missions</h2>
    @if (User.IsInRole("HRAdmin") || User.IsInRole("SystemAdmin"))
    {
        <p>Browse all missions assigned in the HRMS system. Use the button below to assign new ones.</p>
        <a asp-action="AssignMission" class="btn btn-primary">➕ Assign New Mission</a>
    }
    else if (User.IsInRole("LineManager"))
    {
        <p>View missions for your team. <a asp-action="PendingApprovals" class="btn btn-warning">Review Pending Approvals</a></p>
    }
    else
    {
        <p>Browse all missions in the system.</p>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Mission Name</th>
                <th>Destination</th>
                <th>Location</th>
                <th>Employee</th>
                <th>Manager</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var mission in Model)
                {
                    <tr>
                        <td>@mission.MissionName</td>
                        <td>@mission.Destination</td>
                        <td>@mission.Location</td>
                        <td>@mission.Employee?.FullName</td>
                        <td>@mission.Manager?.FullName</td>
                        <td>@mission.StartDate.ToShortDateString()</td>
                        <td>@(mission.EndDate?.ToShortDateString() ?? "N/A")</td>
                        <td>
                            <span class="badge
                                        @(mission.Status == "Approved" || mission.Status == "Completed" ? "bg-success" :
                                                                    mission.Status == "Rejected" ? "bg-danger" :
                                                                    mission.Status == "Pending" ? "bg-warning text-dark" :
                                                                    "bg-info text-dark")">
                                @mission.Status
                            </span>
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Details" asp-route-id="@mission.MissionId" class="btn btn-info btn-sm">Details</a>
                                @if (User.IsInRole("HRAdmin") || User.IsInRole("SystemAdmin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@mission.MissionId" class="btn btn-primary btn-sm">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@mission.MissionId" class="btn btn-danger btn-sm">Delete</a>
                                }
                                @if (User.IsInRole("LineManager") && (mission.Status == "Pending" || mission.Status == "Assigned"))
                                {
                                    <a asp-action="Approve" asp-route-id="@mission.MissionId" class="btn btn-success btn-sm">Approve</a>
                                    <a asp-action="Reject" asp-route-id="@mission.MissionId" class="btn btn-danger btn-sm">Reject</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center">
                        No missions found.
                        @if (User.IsInRole("HRAdmin") || User.IsInRole("SystemAdmin"))
                        {
                            <br />
                            <a asp-action="AssignMission" class="btn btn-primary mt-2">➕ Assign New Mission</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
