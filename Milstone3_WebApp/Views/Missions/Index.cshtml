@model IEnumerable<Milstone3_WebApp.Mission>
@{
    ViewData["Title"] = "Missions";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Missions</h1>
        <p class="page-subtitle">
            @if (User.IsInRole("LineManager")) { <text>Manage and approve team missions</text> }
            else { <text>All missions assigned across the organisation</text> }
        </p>
    </div>
    <div class="d-flex gap-2">
        @if (User.IsInRole("LineManager"))
        {
            <a asp-action="PendingApprovals" class="btn btn-outline-warning btn-sm">
                <i class="bi bi-hourglass-split me-1"></i>Pending approvals
            </a>
        }
        @if (User.IsInRole("HRAdmin") || User.IsInRole("SystemAdmin"))
        {
            <a asp-action="AssignMission" class="btn btn-primary btn-sm">
                <i class="bi bi-plus me-1"></i>Assign mission
            </a>
        }
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="dt-controls px-4 pt-4 pb-2">
            <div class="dt-search">
                <i class="bi bi-search search-icon"></i>
                <input type="text" placeholder="Search missions…"
                       data-dt-search="missionsTable" data-dt-pagesize="15" />
            </div>
            <span class="fs-12 text-muted-custom" data-dt-info="missionsTable"></span>
        </div>

        <div class="admin-table-wrap">
            <table class="admin-table" id="missionsTable">
                <thead>
                    <tr>
                        <th data-sort>Mission</th>
                        <th>Destination</th>
                        <th data-sort>Employee</th>
                        <th>Manager</th>
                        <th data-sort>Start</th>
                        <th>End</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var m in Model)
                        {
                            var pc = (m.Status?.ToLower()) switch {
                                "approved" or "completed" => "pill-approved",
                                "rejected"               => "pill-rejected",
                                "pending"                => "pill-pending",
                                _                        => "pill-onleave"
                            };
                            <tr>
                                <td class="fw-600">@m.MissionName</td>
                                <td class="text-muted-custom">@(m.Destination ?? m.Location ?? "—")</td>
                                <td>@(m.Employee?.FullName ?? "—")</td>
                                <td class="text-muted-custom">@(m.Manager?.FullName ?? "—")</td>
                                <td>@m.StartDate.ToShortDateString()</td>
                                <td class="text-muted-custom">@(m.EndDate?.ToShortDateString() ?? "—")</td>
                                <td><span class="pill @pc">@m.Status</span></td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Details" asp-route-id="@m.MissionId"
                                           class="btn btn-sm btn-outline-secondary">Details</a>
                                        @if (User.IsInRole("HRAdmin") || User.IsInRole("SystemAdmin"))
                                        {
                                            <a asp-action="Edit"   asp-route-id="@m.MissionId" class="btn btn-sm btn-outline-primary">Edit</a>
                                            <a asp-action="Delete" asp-route-id="@m.MissionId" class="btn btn-sm btn-outline-danger">Delete</a>
                                        }
                                        @if (User.IsInRole("LineManager") && (m.Status == "Pending" || m.Status == "Assigned"))
                                        {
                                            <a asp-action="Approve" asp-route-id="@m.MissionId" class="btn btn-sm btn-outline-primary">Approve</a>
                                            <a asp-action="Reject"  asp-route-id="@m.MissionId" class="btn btn-sm btn-outline-danger">Reject</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted-custom">No missions found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="dt-pagination px-4 pb-3">
            <span class="fs-12 text-muted-custom" data-dt-info="missionsTable"></span>
            <div class="dt-page-btns" data-dt-pages="missionsTable"></div>
        </div>
    </div>
</div>
