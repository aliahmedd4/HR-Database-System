@model Milstone3_WebApp.Mission

@{
    ViewData["Title"] = "Mission Details";
}

<div class="welcome-banner">
    <h2>Mission Details</h2>
    <p>Here you can view the full information about this mission assignment.</p>
</div>

<div class="card">
    <h4>@Model.MissionName</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Destination</dt>
        <dd class="col-sm-9">@Model.Destination</dd>

        <dt class="col-sm-3">Mission Name</dt>
        <dd class="col-sm-9">@Model.MissionName</dd>

        <dt class="col-sm-3">Start Date</dt>
        <dd class="col-sm-9">@Model.StartDate ?.ToShortDateString()</dd>

        <dt class="col-sm-3">End Date</dt>
        <dd class="col-sm-9">@Model.EndDate?.ToShortDateString()</dd>

        <dt class="col-sm-3">Location</dt>
        <dd class="col-sm-9">@Model.Location</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Status</dd>

        <dt class="col-sm-3">Completed At</dt>
        <dd class="col-sm-9">@Model.CompletedAt?.ToShortDateString()</dd>

        <dt class="col-sm-3">Assigned By</dt>
        <dd class="col-sm-9">@Model.AssignedByNavigation?.EmployeeId</dd>

        <dt class="col-sm-3">Employee</dt>
        <dd class="col-sm-9">@Model.Employee?.EmployeeId</dd>

        <dt class="col-sm-3">Manager</dt>
        <dd class="col-sm-9">@Model.Manager?.EmployeeId</dd>
    </dl>

    <div class="form-actions">
        <a asp-action="Edit" asp-route-id="@Model?.MissionId" class="btn btn-primary">Edit Mission</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>
